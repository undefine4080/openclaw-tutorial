---
import Layout from '../../layouts/Layout.astro';
import BugSearch from '../../components/BugSearch.astro';
---

<Layout title="Bug 问题库 - OpenClaw 已解决 Bug">
  <main class="bugs-page">
    <!-- 页面标题 -->
    <div class="bugs-header">
      <h1>🐛 Bug 问题库</h1>
      <p>快速找到已解决的 Bug 和解决方案，无需在 GitHub 中搜索</p>
    </div>

    <!-- 搜索框 -->
    <div class="bugs-search-section">
      <BugSearch />
    </div>

    <!-- 统计信息 -->
    <div class="bugs-stats">
      <div class="stat-card">
        <h3>已解决 Bug</h3>
        <p class="stat-number" id="total-bugs">-</p>
      </div>
      <div class="stat-card">
        <h3>本周新增</h3>
        <p class="stat-number">0</p>
      </div>
      <div class="stat-card">
        <h3>平均解决时间</h3>
        <p class="stat-number">2天</p>
      </div>
    </div>

    <!-- Bug 列表 -->
    <div id="bugs-container" class="bugs-list">
      <div class="loading">
        <p>正在加载 Bug 数据...</p>
      </div>
    </div>

    <!-- 加载更多 -->
    <div class="bugs-footer">
      <button id="load-more" class="btn btn-primary" style="display: none;">
        加载更多
      </button>
    </div>
  </main>
</Layout>

<script>
  // 加载 bug reports 数据
  async function loadBugReports() {
    try {
      const response = await fetch('/data/bug-reports/bugs-zh-cn.json');
      const data = await response.json();

      // 更新统计
      const totalBugsElement = document.getElementById('total-bugs');
      if (totalBugsElement) {
        totalBugsElement.textContent = data.meta.total_count;
      }

      // 渲染 bug 列表
      renderBugs(data.bugs);

    } catch (error) {
      console.error('Failed to load bug reports:', error);
      const bugsContainer = document.getElementById('bugs-container');
      if (bugsContainer) {
        bugsContainer.innerHTML =
          '<div class="error-message">' +
          '<p>加载失败，请确保已运行 <code>npm run collect-bugs</code></p>' +
          '<p>并将数据复制到 <code>public/data/bug-reports/</code></p>' +
          '</div>';
      }
    }
  }

  // 渲染 bug cards
  function renderBugs(bugs: any[], page = 1, perPage = 20) {
    const container = document.getElementById('bugs-container');
    if (!container) return;

    const start = (page - 1) * perPage;
    const end = start + perPage;
    const pageBugs = bugs.slice(start, end);

    let html = '';

    pageBugs.forEach((bug: any, index: number) => {
      const title = bug.translations?.zhCN?.title || bug.title;
      const description = bug.translations?.zhCN?.description || bug.description;
      const globalIndex = start + index + 1;

      html += `
        <div class="bug-card">
          <div class="bug-card-header">
            <h2>${globalIndex}. ${title}</h2>
            <span class="badge badge-success">已解决</span>
          </div>

          <div class="bug-meta">
            ${bug.labels.map((label: string) =>
              `<span class="badge">${label}</span>`
            ).join('')}
            <span class="badge badge-info">版本 ${bug.version}</span>
            <span class="badge badge-purple">${bug.platform}</span>
          </div>

          ${bug.error_message ? `
            <div class="error-box">
              <code>${bug.error_message.substring(0, 150)}...</code>
            </div>
          ` : ''}

          <p class="bug-description">
            ${description.substring(0, 300)}${description.length > 300 ? '...' : ''}
          </p>

          <div class="bug-footer">
            <a href="${bug.url}" target="_blank" rel="noopener noreferrer" class="bug-link">
              查看完整讨论 →
            </a>
            <span class="bug-date">
              ${new Date(bug.closed_at).toLocaleDateString('zh-CN')}
            </span>
          </div>
        </div>
      `;
    });

    container.innerHTML = html;

    // 更新加载更多按钮
    const loadMoreBtn = document.getElementById('load-more');
    if (!loadMoreBtn) return;

    if (end >= bugs.length) {
      loadMoreBtn.style.display = 'none';
    } else {
      loadMoreBtn.style.display = 'inline-block';
      loadMoreBtn.onclick = () => renderBugs(bugs, page + 1, perPage);
    }
  }

  // 页面加载时执行
  document.addEventListener('DOMContentLoaded', loadBugReports);
</script>

<style>
  .bugs-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .bugs-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .bugs-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .bugs-header p {
    font-size: 1.25rem;
    color: var(--text-light);
  }

  .bugs-search-section {
    margin-bottom: 2rem;
  }

  .bugs-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: var(--bg-alt);
    padding: 1.5rem;
    border-radius: 8px;
    text-align: center;
  }

  .stat-card h3 {
    font-size: 0.875rem;
    color: var(--text-light);
    margin-bottom: 0.5rem;
  }

  .stat-number {
    font-size: 2rem;
    font-weight: bold;
  }

  .stat-card:nth-child(1) .stat-number { color: #3b82f6; }
  .stat-card:nth-child(2) .stat-number { color: #10b981; }
  .stat-card:nth-child(3) .stat-number { color: #8b5cf6; }

  .bugs-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .loading {
    text-align: center;
    padding: 3rem;
    color: var(--text-light);
  }

  .error-message {
    background: #fee2e2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
  }

  .error-message code {
    background: #fecaca;
    padding: 0.125rem 0.25rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  .bug-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: all 0.2s ease;
  }

  .bug-card:hover {
    border-color: #3b82f6;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .bug-card-header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .bug-card-header h2 {
    font-size: 1.25rem;
    margin: 0;
    color: var(--text);
    flex: 1;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .badge-success {
    background: #d1fae5;
    color: #065f46;
  }

  .badge-info {
    background: #dbeafe;
    color: #1e40af;
  }

  .badge-purple {
    background: #f3e8ff;
    color: #6b21a8;
  }

  .bug-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .bug-meta .badge {
    background: var(--bg-alt);
    color: var(--text-light);
  }

  .error-box {
    background: #fef2f2;
    border-left: 4px solid #ef4444;
    padding: 1rem;
    margin-bottom: 1rem;
    border-radius: 4px;
  }

  .error-box code {
    font-family: 'Monaco', 'Courier New', monospace;
    font-size: 0.875rem;
    color: #991b1b;
    word-break: break-all;
  }

  .bug-description {
    color: var(--text-light);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .bug-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .bug-link {
    color: #3b82f6;
    text-decoration: none;
    font-weight: 500;
  }

  .bug-link:hover {
    text-decoration: underline;
  }

  .bug-date {
    color: #9ca3af;
    font-size: 0.875rem;
  }

  .bugs-footer {
    text-align: center;
    margin-top: 2rem;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary {
    background: #3b82f6;
    color: white;
  }

  .btn-primary:hover {
    background: #2563eb;
  }

  @media (max-width: 768px) {
    .bugs-header h1 {
      font-size: 2rem;
    }

    .bugs-stats {
      grid-template-columns: 1fr;
    }

    .bug-card-header {
      flex-direction: column;
    }
  }
</style>
