---
// Astro 404 页面 - 自动重定向到建设中页面

// 获取当前请求的路径
const currentPath = Astro.url.pathname;

// 判断是否是中文路径
const isZhCN = currentPath.startsWith('/zh-cn');

// 根据语言决定重定向目标
const redirectTarget = isZhCN ? '/zh-cn/construction' : '/construction';

// 设置延迟重定向(毫秒)
const redirectDelay = 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Redirecting... | OpenClaw Tutorial</title>

    <!-- 立即重定向 -->
    <meta http-equiv="refresh" content={`${redirectDelay};url=${redirectTarget}`} />

    <!-- JavaScript 备用重定向方案 -->
    <script is:inline>
      // 立即重定向
      window.location.replace(`${redirectTarget}`);
    </script>

    <style>
      /* 简洁的加载状态 */
      body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
          repeating-linear-gradient(
            90deg,
            transparent,
            transparent 2px,
            rgba(113, 113, 122, 0.03) 2px,
            rgba(113, 113, 122, 0.03) 4px
          ),
          linear-gradient(
            135deg,
            #0a0e27 0%,
            #1a1f3a 50%,
            #0a0e27 100%
          );
        background-attachment: fixed;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      /* 亮色模式背景 */
      html.light-mode body {
        background:
          repeating-linear-gradient(
            90deg,
            transparent,
            transparent 2px,
            rgba(0, 0, 0, 0.02) 2px,
            rgba(0, 0, 0, 0.02) 4px
          ),
          linear-gradient(
            135deg,
            #f9fafb 0%,
            #e5e7eb 50%,
            #f9fafb 100%
          );
      }

      .loading-container {
        text-align: center;
        color: #e4e4e7;
      }

      /* 亮色模式文字 */
      html.light-mode .loading-container {
        color: #111827;
      }

      .loading-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        animation: pulse 1.5s ease-in-out infinite;
      }

      @keyframes pulse {
        0%, 100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.6;
          transform: scale(0.95);
        }
      }

      .loading-text {
        font-size: 1.125rem;
        opacity: 0.9;
      }

      .small-hint {
        margin-top: 1rem;
        font-size: 0.875rem;
        opacity: 0.6;
      }

      .small-hint a {
        color: #e4e4e7;
        text-decoration: underline;
      }

      /* 亮色模式链接 */
      html.light-mode .small-hint a {
        color: #374151;
      }
    </style>
  </head>
  <body>
    <div class="loading-container">
      <div class="loading-icon">🔄</div>
      <div class="loading-text">Redirecting...</div>
      <div class="small-hint">
        If you are not redirected automatically, <a href={redirectTarget} style="color: #e4e4e7;">click here</a>
      </div>
    </div>
  </body>
</html>
