---
// 自动重定向到中文版
return Astro.redirect('/zh-cn/');
---
<style>
  /* ========================================
     钛金属深色拟物化设计风格
     ======================================== */

  /* 基础样式 - 深蓝黑色渐变背景 */
  .homepage {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(113, 113, 122, 0.03) 2px,
        rgba(113, 113, 122, 0.03) 4px
      ),
      linear-gradient(
        135deg,
        #0a0e27 0%,
        #1a1f3a 50%,
        #0a0e27 100%
      );
    background-attachment: fixed;
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section {
    padding: 5rem 0;
  }

  /* 标题 - 钛金属发光效果 */
  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1rem;
    color: #e4e4e7;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-shadow:
      0 0 8px rgba(228, 228, 231, 0.4),
      0 0 16px rgba(228, 228, 231, 0.3),
      0 0 24px rgba(228, 228, 231, 0.2);
    letter-spacing: 0.05em;
  }

  .section-icon {
    font-size: 2.5rem;
    filter: drop-shadow(0 0 8px rgba(212, 212, 216, 0.5));
  }

  .section-subtitle {
    text-align: center;
    color: #a1a1aa;
    font-size: 1.125rem;
    margin-bottom: 3rem;
    font-style: italic;
    text-shadow: 0 0 8px rgba(161, 161, 170, 0.5);
  }

  /* Hero 区域 - 深蓝黑色金属质感 */
  .hero {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.05) 1px,
        rgba(113, 113, 122, 0.05) 2px
      ),
      linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
    position: relative;
    color: #e4e4e7;
    padding: 8rem 0 6rem;
    text-align: center;
    border-bottom: 3px solid #d4d4d8;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.5),
      0 0 30px rgba(228, 228, 231, 0.2);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 10px,
        rgba(228, 228, 231, 0.015) 10px,
        rgba(228, 228, 231, 0.015) 20px
      );
    pointer-events: none;
  }

  .hero-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    text-shadow:
      0 0 15px rgba(228, 228, 231, 0.5),
      0 0 30px rgba(228, 228, 231, 0.3),
      0 4px 8px rgba(0, 0, 0, 0.5);
    letter-spacing: 0.02em;
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    margin-bottom: 2.5rem;
    opacity: 0.95;
    text-shadow:
      0 0 8px rgba(212, 212, 216, 0.4),
      0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* 钛金属拟物化按钮 */
  .cta-button {
    padding: 1rem 2.5rem;
    font-weight: 600;
    text-decoration: none;
    font-size: 1rem;
    position: relative;
    border: none;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .cta-button.primary {
    background: linear-gradient(180deg, #71717a 0%, #52525b 50%, #3f3f46 100%);
    color: #e4e4e7;
    border-radius: 8px;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.2),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 15px rgba(228, 228, 231, 0.3),
      0 4px 8px rgba(0, 0, 0, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .cta-button.secondary {
    background: linear-gradient(180deg, rgba(113, 113, 122, 0.3) 0%, rgba(63, 63, 70, 0.3) 100%);
    color: #e4e4e7;
    border-radius: 8px;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.1),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 12px rgba(228, 228, 231, 0.2);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .cta-button.primary:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.2),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 22px rgba(228, 228, 231, 0.4),
      0 6px 12px rgba(0, 0, 0, 0.4);
  }

  .cta-button.secondary:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.1),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 18px rgba(228, 228, 231, 0.3);
  }

  .cta-button.primary:active {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.4),
      inset 0 -1px 2px rgba(255, 255, 255, 0.1),
      0 0 12px rgba(228, 228, 231, 0.3);
  }

  /* 网格布局 */
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  /* 钛金属拟物化卡片 */
  .card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(228, 228, 231, 0.2),
      0 6px 12px rgba(0, 0, 0, 0.3);
    transition: all 0.2s ease;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(228, 228, 231, 0.4) 0%, transparent 50%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 22px rgba(228, 228, 231, 0.3),
      0 8px 16px rgba(0, 0, 0, 0.4);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #d4d4d8;
  }

  .card-icon {
    font-size: 2.5rem;
    filter: drop-shadow(0 0 8px rgba(212, 212, 216, 0.6));
  }

  .card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #e4e4e7;
    margin: 0;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .card-list {
    list-style: none;
    padding: 0;
  }

  .card-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid #d4d4d8;
  }

  .card-list li:last-child {
    border-bottom: none;
  }

  .card-list a {
    color: #a1a1aa;
    text-decoration: none;
    transition: all 0.2s;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .card-list a:hover {
    color: #e4e4e7;
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.6);
  }

  /* 教程网格 */
  .tutorial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  /* 教程卡片 - 钛金属文件夹效果 */
  .tutorial-card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 18px rgba(228, 228, 231, 0.2),
      0 8px 16px rgba(0, 0, 0, 0.3);
    transition: all 0.2s ease;
  }

  .tutorial-card::before {
    content: '';
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    bottom: 12px;
    border: 2px dashed #e4e4e7;
    border-radius: 8px;
    pointer-events: none;
    opacity: 0.6;
  }

  .tutorial-card:hover {
    transform: translateY(-3px);
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 30px rgba(228, 228, 231, 0.35),
      0 12px 24px rgba(0, 0, 0, 0.4);
  }

  /* 银色金属徽章 */
  .tutorial-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background:
      repeating-linear-gradient(
        90deg,
        #d4d4d8,
        #e4e4e7 2px,
        #d4d4d8 4px
      );
    color: #e4e4e7;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    border: 3px solid #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(228, 228, 231, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.4);
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.6);
  }

  .tutorial-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e4e4e7;
    margin: 0 0 0.5rem 0;
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.5);
  }

  .tutorial-description {
    color: #a1a1aa;
    margin-bottom: 1.5rem;
    font-style: italic;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .tutorial-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  /* 标签 - 银色光晕效果 */
  .topic {
    background: linear-gradient(180deg, rgba(228, 228, 231, 0.2) 0%, rgba(212, 212, 216, 0.15) 100%);
    color: #e4e4e7;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    font-size: 0.875rem;
    border: 1px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 8px rgba(228, 228, 231, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.5);
  }

  .tutorial-link {
    color: #e4e4e7;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .tutorial-link:hover {
    color: #d4d4d8;
    text-shadow: 0 0 12px rgba(212, 212, 216, 0.6);
    text-decoration: underline;
  }

  /* 疑难解答板块 */
  .troubleshooting-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
  }

  /* 搜索卡片 - 钛金属质感 */
  .search-card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.15) 1px,
        rgba(113, 113, 122, 0.15) 2px
      ),
      linear-gradient(135deg, #71717a 0%, #52525b 50%, #3f3f46 100%);
    color: #e4e4e7;
    border-radius: 12px;
    padding: 2.5rem;
    text-align: center;
    border: 3px solid #e4e4e7;
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.5),
      0 0 22px rgba(228, 228, 231, 0.35),
      0 8px 16px rgba(0, 0, 0, 0.4);
  }

  .search-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 12px rgba(212, 212, 216, 0.6));
  }

  .search-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.5);
  }

  .search-card p {
    margin-bottom: 1.5rem;
    opacity: 0.9;
    text-shadow: 0 0 8px rgba(161, 161, 170, 0.5);
  }

  .search-button {
    display: inline-block;
    background: linear-gradient(180deg, #a1a1aa 0%, #71717a 100%);
    color: #e4e4e7;
    padding: 0.85rem 2.25rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 15px rgba(228, 228, 231, 0.4),
      0 4px 8px rgba(0, 0, 0, 0.3);
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.6);
    transition: all 0.15s ease;
  }

  .search-button:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 22px rgba(228, 228, 231, 0.6),
      0 6px 12px rgba(0, 0, 0, 0.4);
  }

  .search-button:active {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.4),
      0 0 12px rgba(228, 228, 231, 0.4);
  }

  /* 问题列表 - 深色便签效果 */
  .issues-list {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.08) 1px,
        rgba(113, 113, 122, 0.08) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2rem;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 6px 12px rgba(0, 0, 0, 0.3);
  }

  .issues-list h3 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    color: #e4e4e7;
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.4);
  }

  .issue-items {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 0.75rem;
  }

  .issue-item {
    display: block;
    padding: 0.85rem 1.15rem;
    background: linear-gradient(180deg, rgba(39, 39, 42, 0.8) 0%, rgba(24, 24, 27, 0.8) 100%);
    border-radius: 6px;
    color: #a1a1aa;
    text-decoration: none;
    transition: all 0.2s;
    font-size: 0.9375rem;
    border: 1px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 2px 4px rgba(0, 0, 0, 0.2);
  }

  .issue-item:hover {
    background: linear-gradient(180deg, rgba(161, 161, 170, 0.2) 0%, rgba(113, 113, 122, 0.15) 100%);
    color: #e4e4e7;
    transform: translateX(4px);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 12px rgba(228, 228, 231, 0.4);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.5);
  }

  /* 成本计算器 - 钛金属卡片 */
  .calculator-preview {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 0 18px rgba(228, 228, 231, 0.2),
      0 8px 16px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    border: 2px solid #d4d4d8;
  }

  .preview-content {
    padding: 3rem;
    text-align: center;
  }

  .preview-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 12px rgba(212, 212, 216, 0.6));
  }

  .preview-content h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: #e4e4e7;
    text-shadow: 0 0 12px rgba(228, 228, 231, 0.5);
  }

  .preview-content p {
    color: #a1a1aa;
    margin-bottom: 1.5rem;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
    display: inline-block;
    text-align: left;
  }

  .feature-list li {
    padding: 0.6rem 0;
    color: #e4e4e7;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .preview-button {
    display: inline-block;
    background: linear-gradient(180deg, #a1a1aa 0%, #71717a 100%);
    color: #e4e4e7;
    padding: 1rem 2.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 18px rgba(228, 228, 231, 0.4),
      0 4px 8px rgba(0, 0, 0, 0.3);
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.6);
    transition: all 0.15s ease;
  }

  .preview-button:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 26px rgba(228, 228, 231, 0.6),
      0 6px 12px rgba(0, 0, 0, 0.4);
  }

  .preview-button:active {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(228, 228, 231, 0.4);
  }

  /* 社区板块 */
  .community-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  /* 社区板块 - 钛金属卡片 */
  .community-card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2rem;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 0 15px rgba(228, 228, 231, 0.2),
      0 6px 12px rgba(0, 0, 0, 0.3);
  }

  .community-card .card-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 10px rgba(212, 212, 216, 0.6));
  }

  .community-card h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    color: #e4e4e7;
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.4);
  }

  .link-list {
    list-style: none;
    padding: 0;
  }

  .link-list li {
    padding: 0.6rem 0;
  }

  .link-list a {
    color: #a1a1aa;
    text-decoration: none;
    transition: all 0.2s;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .link-list a:hover {
    color: #e4e4e7;
    text-shadow: 0 0 12px rgba(228, 228, 231, 0.6);
    text-decoration: underline;
  }

  /* 页脚 - 深色金属质感 */
  .footer {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(113, 113, 122, 0.1) 2px,
        rgba(113, 113, 122, 0.1) 4px
      ),
      linear-gradient(
        180deg,
        #18181b 0%,
        #0a0a0a 100%
