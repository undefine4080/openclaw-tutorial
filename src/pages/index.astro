---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OpenClaw: From Beginner to Master" currentPath="/">
  <div class="homepage">
    <!-- Hero Section -->
    <section class="hero" id="hero">
      <div class="hero-container">
        <h1 class="hero-title">OpenClaw: From Beginner to Master</h1>
        <p class="hero-subtitle">
          Comprehensive tutorials to master OpenClaw, from installation to advanced multi-agent systems
        </p>
        <div class="hero-cta">
          <a href="#tutorials-01" class="cta-button primary">View Tutorials</a>
          <a href="#troubleshooting" class="cta-button secondary">Troubleshooting</a>
        </div>
      </div>
    </section>

    <!-- Installation Section -->
    <section class="section installation" id="installation">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">⚙️</span>
          Installation & Deployment
        </h2>
        <p class="section-subtitle">Get OpenClaw running on your local machine or deploy to the cloud</p>

        <div class="grid-3">
          <!-- Local Installation -->
          <div class="card">
            <div class="card-header">
              <div class="card-icon">💻</div>
              <h3>Local Installation</h3>
            </div>
            <ul class="card-list">
              <li><a href="#">macOS Setup</a></li>
              <li><a href="#">Linux Installation</a></li>
              <li><a href="#">Windows Setup</a></li>
            </ul>
          </div>

          <!-- Cloud Deployment -->
          <div class="card">
            <div class="card-header">
              <div class="card-icon">☁️</div>
              <h3>Cloud Deployment</h3>
            </div>
            <ul class="card-list">
              <li><a href="#">Alibaba Cloud</a></li>
              <li><a href="#">Tencent Cloud</a></li>
              <li><a href="#">Volc Engine</a></li>
            </ul>
          </div>

          <!-- One-Click Platforms -->
          <div class="card">
            <div class="card-header">
              <div class="card-icon">🚀</div>
              <h3>One-Click Platforms</h3>
            </div>
            <ul class="card-list">
              <li><a href="#">ByteDance ArkClaw</a></li>
              <li><a href="#">Tencent QClaw</a></li>
              <li><a href="#">Zhipu AutoClaw</a></li>
              <li><a href="#">Liebao EasyClaw</a></li>
              <li><a href="#">Tencent WorkBuddy</a></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Tutorials Section -->
    <section class="section tutorials" id="tutorials">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">📚</span>
          Tutorial Categories
        </h2>
        <p class="section-subtitle">Master OpenClaw step by step with our comprehensive guides</p>

        <div class="tutorial-grid">
          <!-- 01 Getting Started -->
          <div class="tutorial-card" id="tutorials-01">
            <div class="tutorial-badge">01</div>
            <h3 class="tutorial-title">Getting Started</h3>
            <p class="tutorial-description">Begin your journey with OpenClaw</p>
            <div class="tutorial-topics">
              <span class="topic">Model Integration</span>
              <span class="topic">Feishu</span>
              <span class="topic">WeChat</span>
              <span class="topic">QQ</span>
              <span class="topic">WeCom</span>
            </div>
            <a href="#" class="tutorial-link">View Tutorials →</a>
          </div>

          <!-- 02 Initialize OpenClaw -->
          <div class="tutorial-card" id="tutorials-02">
            <div class="tutorial-badge">02</div>
            <h3 class="tutorial-title">Initialize OpenClaw</h3>
            <p class="tutorial-description">Configure your OpenClaw instance</p>
            <div class="tutorial-topics">
              <span class="topic">AGENTS.md</span>
              <span class="topic">USER.md</span>
              <span class="topic">SOUL.md</span>
            </div>
            <a href="#" class="tutorial-link">View Tutorials →</a>
          </div>

          <!-- 03 OpenClaw Vision -->
          <div class="tutorial-card" id="tutorials-03">
            <div class="tutorial-badge">03</div>
            <h3 class="tutorial-title">OpenClaw Vision</h3>
            <p class="tutorial-description">Visual capabilities for image understanding</p>
            <div class="tutorial-topics">
              <span class="topic">Visual Capability</span>
              <span class="topic">Image Processing</span>
              <span class="topic">Video Understanding</span>
            </div>
            <a href="#" class="tutorial-link">View Tutorials →</a>
          </div>

          <!-- 04 OpenClaw Tools -->
          <div class="tutorial-card" id="tutorials-04">
            <div class="tutorial-badge">04</div>
            <h3 class="tutorial-title">OpenClaw Tools</h3>
            <p class="tutorial-description">Extend functionality with tools</p>
            <div class="tutorial-topics">
              <span class="topic">Tool Calling</span>
              <span class="topic">API Integration</span>
              <span class="topic">Automation</span>
            </div>
            <a href="#" class="tutorial-link">View Tutorials →</a>
          </div>

          <!-- 05 OpenClaw Brain -->
          <div class="tutorial-card" id="tutorials-05">
            <div class="tutorial-badge">05</div>
            <h3 class="tutorial-title">OpenClaw Brain</h3>
            <p class="tutorial-description">Memory and collaboration systems</p>
            <div class="tutorial-topics">
              <span class="topic">Memory System</span>
              <span class="topic">Collaboration</span>
              <span class="topic">Context Management</span>
            </div>
            <a href="#" class="tutorial-link">View Tutorials →</a>
          </div>

          <!-- 06 Essential Skills -->
          <div class="tutorial-card" id="tutorials-06">
            <div class="tutorial-badge">06</div>
            <h3 class="tutorial-title">Essential Skills</h3>
            <p class="tutorial-description">Must-have skills for OpenClaw users</p>
            <div class="tutorial-topics">
              <span class="topic">Beginner Essentials</span>
              <span class="topic">Dev Popular</span>
              <span class="topic">Media Popular</span>
              <span class="topic">General Popular</span>
            </div>
            <a href="#" class="tutorial-link">View Tutorials →</a>
          </div>

          <!-- 07 Multi-Agent -->
          <div class="tutorial-card" id="tutorials-07">
            <div class="tutorial-badge">07</div>
            <h3 class="tutorial-title">Multi-Agent Systems</h3>
            <p class="tutorial-description">Advanced multi-agent capabilities</p>
            <div class="tutorial-topics">
              <span class="topic">Basic</span>
              <span class="topic">Advanced</span>
            </div>
            <a href="#" class="tutorial-link">View Tutorials →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Troubleshooting Section -->
    <section class="section troubleshooting" id="troubleshooting">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">🔧</span>
          Troubleshooting
        </h2>
        <p class="section-subtitle">Quick solutions to common OpenClaw issues</p>

        <div class="troubleshooting-grid">
          <!-- Search Box -->
          <div class="search-card">
            <div class="search-icon">🔍</div>
            <h3>Search GitHub Issues</h3>
            <p>Find solutions from the community</p>
            <a href="/bugs/" class="search-button">Search Issues</a>
          </div>

          <!-- Common Issues -->
          <div class="issues-list">
            <h3>Common Issues</h3>
            <div class="issue-items">
              <a href="#" class="issue-item">1. Port already in use</a>
              <a href="#" class="issue-item">2. Permission denied errors</a>
              <a href="#" class="issue-item">3. Gateway connection failed</a>
              <a href="#" class="issue-item">4. Model API key issues</a>
              <a href="#" class="issue-item">5. Node.js version compatibility</a>
              <a href="#" class="issue-item">6. Memory allocation problems</a>
              <a href="#" class="issue-item">7. File path errors</a>
              <a href="#" class="issue-item">8. Network timeout issues</a>
              <a href="#" class="issue-item">9. Configuration file errors</a>
              <a href="#" class="issue-item">10. Dependency conflicts</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Cost Calculator Section -->
    <section class="section cost-calculator" id="cost-calculator">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">💰</span>
          Cost Calculator
        </h2>
        <p class="section-subtitle">Estimate your OpenClaw running costs</p>

        <div class="calculator-preview">
          <div class="preview-content">
            <div class="preview-icon">🧮</div>
            <h3>Calculate Your Costs</h3>
            <p>Estimate monthly expenses for running OpenClaw based on your usage patterns and chosen AI models</p>
            <ul class="feature-list">
              <li>✓ Model API costs comparison</li>
              <li>✓ Server hosting estimates</li>
              <li>✓ Usage-based calculations</li>
            </ul>
            <a href="#" class="preview-button">Open Calculator →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Community Section -->
    <section class="section community" id="community">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">👥</span>
          Community & Resources
        </h2>
        <p class="section-subtitle">Join the community and access helpful resources</p>

        <div class="community-grid">
          <!-- Community Links -->
          <div class="community-card">
            <div class="card-icon">🌐</div>
            <h3>Community Platforms</h3>
            <ul class="link-list">
              <li><a href="#" target="_blank" rel="noopener">ClawHub</a></li>
              <li><a href="https://github.com/openclaw/openclaw" target="_blank" rel="noopener">OpenClaw GitHub</a></li>
            </ul>
          </div>

          <!-- Resources -->
          <div class="community-card">
            <div class="card-icon">📥</div>
            <h3>Essential Downloads</h3>
            <ul class="link-list">
              <li><a href="https://nodejs.org/" target="_blank" rel="noopener">Node.js 22+</a></li>
              <li><a href="https://ubuntu.com/download" target="_blank" rel="noopener">Ubuntu Server</a></li>
              <li><a href="https://git-scm.com/" target="_blank" rel="noopener">Git</a></li>
              <li><a href="https://claude.ai/code" target="_blank" rel="noopener">Claude Code</a></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div class="disclaimer">
            <strong>Disclaimer:</strong> This website is an independent tutorial resource and is not affiliated with the official OpenClaw project.
            For official documentation, visit <a href="https://github.com/openclaw/openclaw" target="_blank" rel="noopener">GitHub</a>.
          </div>
          <div class="footer-links">
            <span>© 2024 OpenClaw Tutorial</span>
          </div>
        </div>
      </div>
    </footer>
  </div>
</Layout>

</style>
<style>
  /* ========================================
     钛金属深色拟物化设计风格
     ======================================== */

  /* 基础样式 - 深蓝黑色渐变背景 */
  .homepage {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(113, 113, 122, 0.03) 2px,
        rgba(113, 113, 122, 0.03) 4px
      ),
      linear-gradient(
        135deg,
        #0a0e27 0%,
        #1a1f3a 50%,
        #0a0e27 100%
      );
    background-attachment: fixed;
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section {
    padding: 5rem 0;
  }

  /* 标题 - 钛金属发光效果 */
  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1rem;
    color: #e4e4e7;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-shadow:
      0 0 8px rgba(228, 228, 231, 0.4),
      0 0 16px rgba(228, 228, 231, 0.3),
      0 0 24px rgba(228, 228, 231, 0.2);
    letter-spacing: 0.05em;
  }

  .section-icon {
    font-size: 2.5rem;
    filter: drop-shadow(0 0 8px rgba(212, 212, 216, 0.5));
  }

  .section-subtitle {
    text-align: center;
    color: #a1a1aa;
    font-size: 1.125rem;
    margin-bottom: 3rem;
    font-style: italic;
    text-shadow: 0 0 8px rgba(161, 161, 170, 0.5);
  }

  /* Hero 区域 - 深蓝黑色金属质感 */
  .hero {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.05) 1px,
        rgba(113, 113, 122, 0.05) 2px
      ),
      linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
    position: relative;
    color: #e4e4e7;
    padding: 8rem 0 6rem;
    text-align: center;
    border-bottom: 3px solid #d4d4d8;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.5),
      0 0 30px rgba(228, 228, 231, 0.2);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 10px,
        rgba(228, 228, 231, 0.015) 10px,
        rgba(228, 228, 231, 0.015) 20px
      );
    pointer-events: none;
  }

  .hero-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    text-shadow:
      0 0 15px rgba(228, 228, 231, 0.5),
      0 0 30px rgba(228, 228, 231, 0.3),
      0 4px 8px rgba(0, 0, 0, 0.5);
    letter-spacing: 0.02em;
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    margin-bottom: 2.5rem;
    opacity: 0.95;
    text-shadow:
      0 0 8px rgba(212, 212, 216, 0.4),
      0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* 钛金属拟物化按钮 */
  .cta-button {
    padding: 1rem 2.5rem;
    font-weight: 600;
    text-decoration: none;
    font-size: 1rem;
    position: relative;
    border: none;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .cta-button.primary {
    background: linear-gradient(180deg, #71717a 0%, #52525b 50%, #3f3f46 100%);
    color: #e4e4e7;
    border-radius: 8px;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.2),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 15px rgba(228, 228, 231, 0.3),
      0 4px 8px rgba(0, 0, 0, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .cta-button.secondary {
    background: linear-gradient(180deg, rgba(113, 113, 122, 0.3) 0%, rgba(63, 63, 70, 0.3) 100%);
    color: #e4e4e7;
    border-radius: 8px;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.1),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 12px rgba(228, 228, 231, 0.2);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .cta-button.primary:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.2),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 22px rgba(228, 228, 231, 0.4),
      0 6px 12px rgba(0, 0, 0, 0.4);
  }

  .cta-button.secondary:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.1),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 18px rgba(228, 228, 231, 0.3);
  }

  .cta-button.primary:active {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.4),
      inset 0 -1px 2px rgba(255, 255, 255, 0.1),
      0 0 12px rgba(228, 228, 231, 0.3);
  }

  /* 网格布局 */
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  /* 钛金属拟物化卡片 */
  .card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(228, 228, 231, 0.2),
      0 6px 12px rgba(0, 0, 0, 0.3);
    transition: all 0.2s ease;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(228, 228, 231, 0.4) 0%, transparent 50%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 22px rgba(228, 228, 231, 0.3),
      0 8px 16px rgba(0, 0, 0, 0.4);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #d4d4d8;
  }

  .card-icon {
    font-size: 2.5rem;
    filter: drop-shadow(0 0 8px rgba(212, 212, 216, 0.6));
  }

  .card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #e4e4e7;
    margin: 0;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .card-list {
    list-style: none;
    padding: 0;
  }

  .card-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid #d4d4d8;
  }

  .card-list li:last-child {
    border-bottom: none;
  }

  .card-list a {
    color: #a1a1aa;
    text-decoration: none;
    transition: all 0.2s;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .card-list a:hover {
    color: #e4e4e7;
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.6);
  }

  /* 教程网格 */
  .tutorial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  /* 教程卡片 - 钛金属文件夹效果 */
  .tutorial-card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 18px rgba(228, 228, 231, 0.2),
      0 8px 16px rgba(0, 0, 0, 0.3);
    transition: all 0.2s ease;
  }

  .tutorial-card::before {
    content: '';
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    bottom: 12px;
    border: 2px dashed #e4e4e7;
    border-radius: 8px;
    pointer-events: none;
    opacity: 0.6;
  }

  .tutorial-card:hover {
    transform: translateY(-3px);
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 30px rgba(228, 228, 231, 0.35),
      0 12px 24px rgba(0, 0, 0, 0.4);
  }

  /* 银色金属徽章 */
  .tutorial-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background:
      repeating-linear-gradient(
        90deg,
        #d4d4d8,
        #e4e4e7 2px,
        #d4d4d8 4px
      );
    color: #e4e4e7;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    border: 3px solid #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(228, 228, 231, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.4);
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.6);
  }

  .tutorial-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e4e4e7;
    margin: 0 0 0.5rem 0;
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.5);
  }

  .tutorial-description {
    color: #a1a1aa;
    margin-bottom: 1.5rem;
    font-style: italic;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .tutorial-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  /* 标签 - 银色光晕效果 */
  .topic {
    background: linear-gradient(180deg, rgba(228, 228, 231, 0.2) 0%, rgba(212, 212, 216, 0.15) 100%);
    color: #e4e4e7;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    font-size: 0.875rem;
    border: 1px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
