---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="社区与资源 - OpenClaw 教程" currentPath="/zh-cn/community/">
  <div class="community-page">
    <!-- 页面头部 -->
    <div class="page-header">
      <div class="container">
        <div class="breadcrumb">
          <a href="/zh-cn/">首页</a>
          <span class="separator">→</span>
          <span class="current">社区与资源</span>
        </div>
        <h1 class="page-title">社区与资源</h1>
        <p class="page-subtitle">加入社区，获取帮助，下载必备工具</p>
      </div>
    </div>

    <!-- 为什么加入社区 -->
    <section class="intro-section">
      <div class="container">
        <div class="intro-grid">
          <div class="intro-item">
            <div class="intro-icon">📚</div>
            <h3>学习资源</h3>
            <p>获取独家教程和指南</p>
          </div>
          <div class="intro-item">
            <div class="intro-icon">🤝</div>
            <h3>技术支持</h3>
            <p>从社区获得帮助</p>
          </div>
          <div class="intro-item">
            <div class="intro-icon">💡</div>
            <h3>经验分享</h3>
            <p>学习他人的最佳实践</p>
          </div>
          <div class="intro-item">
            <div class="intro-icon">🚀</div>
            <h3>最新动态</h3>
            <p>了解功能更新和发布</p>
          </div>
          <div class="intro-item">
            <div class="intro-icon">🎁</div>
            <h3>独家插件</h3>
            <p>访问社区贡献的扩展</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 社区平台 -->
    <section class="community-section">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">👥</span>
          加入社区
        </h2>
        <p class="section-subtitle">与其他用户交流，获取帮助和分享经验</p>

        <div class="community-grid">
          <!-- ClawHub -->
          <div class="community-card featured">
            <div class="card-badge">官方推荐</div>
            <div class="card-icon">🦞</div>
            <h3>ClawHub</h3>
            <p>OpenClaw 官方社区，与全球用户交流</p>
            <ul class="feature-list">
              <li>✓ 问答讨论</li>
              <li>✓ 经验分享</li>
              <li>✓ 插件发布</li>
              <li>✓ 官方公告</li>
            </ul>
            <a href="https://github.com/openclaw/openclaw" class="btn-primary" target="_blank" rel="noopener">
              访问 ClawHub →
            </a>
          </div>

          <!-- GitHub -->
          <div class="community-card">
            <div class="card-icon">🐙</div>
            <h3>GitHub</h3>
            <p>OpenClaw 开源仓库</p>
            <ul class="feature-list">
              <li>✓ 源代码</li>
              <li>✓ 问题追踪</li>
              <li>✓ 功能请求</li>
              <li>✓ 贡献指南</li>
            </ul>
            <a href="https://github.com/openclaw/openclaw" class="btn-secondary" target="_blank" rel="noopener">
              访问 GitHub →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 资源下载 -->
    <section class="resources-section">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">📦</span>
          必备资源下载
        </h2>
        <p class="section-subtitle">开始使用 OpenClaw 前需要的工具和软件</p>

        <div class="resources-grid">
          <!-- Node.js -->
          <div class="resource-card">
            <div class="resource-icon">🟢</div>
            <h3>Node.js</h3>
            <p class="version">v22 LTS</p>
            <p>JavaScript 运行时，OpenClaw 的基础环境</p>
            <div class="requirement">
              <span class="badge required">必需</span>
              <span>最低版本：22.0.0</span>
            </div>
            <a href="https://nodejs.org/" class="download-btn" target="_blank" rel="noopener">
              下载 Node.js →
            </a>
          </div>

          <!-- Ubuntu -->
          <div class="resource-card">
            <div class="resource-icon">🟠</div>
            <h3>Ubuntu</h3>
            <p class="version">22.04 LTS / 24.04 LTS</p>
            <p>推荐的 Linux 发行版，适合服务器部署</p>
            <div class="requirement">
              <span class="badge optional">可选</span>
              <span>用于云端部署</span>
            </div>
            <a href="https://ubuntu.com/download" class="download-btn" target="_blank" rel="noopener">
              下载 Ubuntu →
            </a>
          </div>

          <!-- Git -->
          <div class="resource-card">
            <div class="resource-icon">🔵</div>
            <h3>Git</h3>
            <p class="version">Latest</p>
            <p>版本控制系统，用于克隆和管理代码</p>
            <div class="requirement">
              <span class="badge recommended">推荐</span>
              <span>便于获取更新</span>
            </div>
            <a href="https://git-scm.com/" class="download-btn" target="_blank" rel="noopener">
              下载 Git →
            </a>
          </div>

          <!-- Claude Code -->
          <div class="resource-card">
            <div class="resource-icon">🤖</div>
            <h3>Claude Code</h3>
            <p class="version">Latest</p>
            <p>Anthropic 的 AI 编程助手，提升开发效率</p>
            <div class="requirement">
              <span class="badge optional">可选</span>
              <span>辅助开发工具</span>
            </div>
            <a href="https://claude.ai/code" class="download-btn" target="_blank" rel="noopener">
              获取 Claude Code →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 贡献方式 -->
    <section class="contribution-section">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">🤝</span>
          贡献方式
        </h2>
        <p class="section-subtitle">为 OpenClaw 社区做出贡献</p>

        <div class="contribution-list">
          <div class="contribution-item">
            <div class="contribution-number">1</div>
            <h3>回答问题</h3>
            <p>帮助新手解决问题，在社区分享你的知识</p>
          </div>
          <div class="contribution-item">
            <div class="contribution-number">2</div>
            <h3>分享经验</h3>
            <p>发布使用技巧、教程和最佳实践</p>
          </div>
          <div class="contribution-item">
            <div class="contribution-number">3</div>
            <h3>报告 Bug</h3>
            <p>帮助改进项目，让 OpenClaw 更加稳定</p>
          </div>
          <div class="contribution-item">
            <div class="contribution-number">4</div>
            <h3>贡献代码</h3>
            <p>提交 Pull Request，直接参与开发</p>
          </div>
          <div class="contribution-item">
            <div class="contribution-number">5</div>
            <h3>开发插件</h3>
            <p>扩展 OpenClaw 功能，丰富生态系统</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 更多资源 -->
    <section class="more-resources">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">🔗</span>
          更多资源
        </h2>

        <div class="link-list">
          <a href="https://github.com/openclaw/openclaw" class="link-item" target="_blank" rel="noopener">
            <div class="link-content">
              <span class="link-title">官方文档</span>
              <span class="link-desc">OpenClaw 官方文档网站</span>
            </div>
            <span class="link-arrow">→</span>
          </a>

          <a href="https://github.com/openclaw/openclaw" class="link-item" target="_blank" rel="noopener">
            <div class="link-content">
              <span class="link-title">API 参考</span>
              <span class="link-desc">完整的 API 文档和示例</span>
            </div>
            <span class="link-arrow">→</span>
          </a>

          <a href="https://github.com/openclaw/openclaw" class="link-item" target="_blank" rel="noopener">
            <div class="link-content">
              <span class="link-title">插件市场</span>
              <span class="link-desc">社区贡献的扩展插件</span>
            </div>
            <span class="link-arrow">→</span>
          </a>

          <a href="https://github.com/openclaw/openclaw" class="link-item" target="_blank" rel="noopener">
            <div class="link-content">
              <span class="link-title">视频教程</span>
              <span class="link-desc">YouTube/Bilibili 教程合集</span>
            </div>
            <span class="link-arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- 页脚 -->
    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div class="disclaimer">
            <strong>免责声明：</strong>本网站是独立的教程资源，与 OpenClaw 官方项目无关联。
            访问 <a href="https://github.com/openclaw/openclaw" target="_blank" rel="noopener">GitHub</a> 查看官方文档。
          </div>
          <div class="footer-links">
            <span>© 2024 OpenClaw Tutorial</span>
          </div>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style>
  /* 基础样式 */
  .community-page {
    background: #f9fafb;
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* 页面头部 */
  .page-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 4rem 0 3rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: white;
  }

  .separator {
    color: rgba(255, 255, 255, 0.6);
  }

  .current {
    color: white;
    font-weight: 600;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .page-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    opacity: 0.9;
  }

  /* 板块通用样式 */
  section {
    padding: 4rem 0;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1rem;
    color: #1f2937;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .section-icon {
    font-size: 2.5rem;
  }

  .section-subtitle {
    text-align: center;
    color: #6b7280;
    font-size: 1.125rem;
    margin-bottom: 3rem;
  }

  /* 介绍网格 */
  .intro-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .intro-item {
    text-align: center;
    padding: 2rem 1rem;
    background: white;
    border-radius: 0.75rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
    transition: all 0.3s;
  }

  .intro-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
  }

  .intro-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .intro-item h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1f2937;
    margin-bottom: 0.5rem;
  }

  .intro-item p {
    color: #6b7280;
    font-size: 0.9375rem;
  }

  /* 社区卡片网格 */
  .community-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .community-grid {
      grid-template-columns: 1fr;
    }
  }

  .community-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    padding: 2.5rem;
    position: relative;
    transition: all 0.3s;
  }

  .community-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .community-card.featured {
    border-color: #667eea;
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.15);
  }

  .card-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .card-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .community-card h3 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 0.75rem;
  }

  .community-card > p {
    color: #6b7280;
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
  }

  .feature-list li {
    padding: 0.5rem 0;
    color: #666;
    font-size: 0.9375rem;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-block;
    padding: 0.875rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
  }

  .btn-secondary {
    background: white;
    color: #667eea;
    border: 2px solid #667eea;
  }

  .btn-secondary:hover {
    background: #667eea;
    color: white;
  }

  /* 资源卡片网格 */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (max-width: 1024px) {
    .resources-grid {
      grid-template-columns: 1fr;
    }
  }

  .resource-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 2rem;
    transition: all 0.2s;
  }

  .resource-card:hover {
    border-color: #667eea;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.1);
  }

  .resource-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .resource-card h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 0.25rem;
  }

  .version {
    color: #667eea;
    font-weight: 600;
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .resource-card > p {
    color: #6b7280;
    font-size: 0.9375rem;
    margin-bottom: 1rem;
  }

  .requirement {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 0;
  }

  .badge {
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .badge.required {
    background: #fee2e2;
    color: #991b1b;
  }

  .badge.recommended {
    background: #fef3c7;
    color: #92400e;
  }

  .badge.optional {
    background: #d1fae5;
    color: #065f46;
  }

  .download-btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
  }

  .download-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
  }

  /* 贡献方式 */
  .contribution-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .contribution-item {
    background: white;
    border-radius: 0.75rem;
    padding: 2rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contribution-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
  }

  .contribution-number {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .contribution-item h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1f2937;
    margin-bottom: 0.5rem;
  }

  .contribution-item p {
    color: #6b7280;
    font-size: 0.9375rem;
  }

  /* 链接列表 */
  .link-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 2rem 0;
  }

  .link-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .link-item:hover {
    background: white;
    border-color: #667eea;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.1);
  }

  .link-content {
    flex: 1;
  }

  .link-title {
    font-weight: 600;
    color: #1a1a1a;
    display: block;
    margin-bottom: 0.25rem;
  }

  .link-desc {
    color: #666;
    font-size: 0.875rem;
  }

  .link-arrow {
    font-size: 1.5rem;
    color: #667eea;
  }

  /* 页脚 */
  .footer {
    background: #1f2937;
    color: white;
    padding: 3rem 0;
    margin-top: 5rem;
  }

  .footer-content {
    text-align: center;
  }

  .disclaimer {
    background: rgba(255, 255, 255, 0.1);
    padding: 1.5rem;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .disclaimer a {
    color: #60a5fa;
    text-decoration: underline;
  }

  .footer-links {
    color: #9ca3af;
    font-size: 0.875rem;
  }

  /* 响应式设计 */
  @media (max-width: 768px) {
    section {
      padding: 3rem 0;
    }

    .section-title {
      font-size: 2rem;
    }

    .intro-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .link-item {
      padding: 1rem 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .container {
      padding: 0 1rem;
    }

    .intro-grid {
      grid-template-columns: 1fr;
    }

    .page-header {
      padding: 3rem 0 2rem;
    }
  }
</style>
