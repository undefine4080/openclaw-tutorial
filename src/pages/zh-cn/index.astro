  .card-desc {
    color: #71717a;
    font-size: 0.875rem;
    margin: 0;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .link-list-enhanced {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .link-list-enhanced li {
    border-bottom: 1px solid rgba(212, 212, 216, 0.1);
  }

  .link-list-enhanced li:last-child {
    border-bottom: none;
  }

  .link-list-enhanced a {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    color: #a1a1aa;
    text-decoration: none;
