  /* 响应式设计 */
  @media (max-width: 1024px) {
    .troubleshooting-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 2rem;
    }

    .grid-3 {
      grid-template-columns: 1fr;
    }

    .tutorial-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 6rem 0 4rem;
    }

    .issue-items {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .container {
      padding: 0 1rem;
    }

    .section {
      padding: 3rem 0;
    }

    .hero-cta {
      flex-direction: column;
    }

    .cta-button {
      width: 100%;
    }
  }

