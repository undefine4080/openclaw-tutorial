---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

// 获取所有已发布的文章
const allPosts = await getCollection(
  "posts-zh-cn",
  ({ data }) => data.status === "published",
);

// 按发布日期排序，取最新的 3 篇文章
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);

const totalPosts = allPosts.length;

const pageTitle = "OpenClaw 教程 - 安装部署、使用技巧与故障排除完整指南";
const pageDescription = "最全面的 OpenClaw 中文教程网站，提供从零基础到精通的完整学习路径。5分钟快速完成本地安装与云端部署，30秒精准定位并解决常见故障。涵盖本地环境配置、云端服务器部署、多AI模型接入、工具调用、Agent开发、最佳实践等深度内容，持续更新中。";

// 难度映射
const difficultyMap: Record<string, string> = {
  beginner: "入门",
  intermediate: "中等",
  advanced: "高级",
};

// 难度样式映射
const difficultyClassMap: Record<string, string> = {
  beginner: "beginner",
  intermediate: "intermediate",
  advanced: "advanced",
};
---

<Layout
	title={pageTitle}
	description={pageDescription}
	currentPath="/zh-cn/"
	lang="zh-CN"
>
  <div class="homepage">
    <!-- Hero 区域 -->
    <section class="hero" id="hero">
      <div class="hero-container">
        <h1 class="hero-title">
          <span class="title-highlight">OpenClaw</span> 教程：安装部署与故障排除指南
        </h1>
        <p class="hero-subtitle">最全面的中文教程，助你快速掌握 OpenClaw 所有功能</p>
        <p class="hero-stats">
          已更新 <span class="stats-count">{totalPosts}</span> 篇文章
        </p>
        <div class="hero-cta">
          <a href="/zh-cn/tutorials/installation/" class="cta-button primary"
            >查看教程</a
          >
          <a href="/zh-cn/bugs/" class="cta-button secondary">疑难解答</a>
        </div>
      </div>
    </section>

    <!-- 最新文章板块 -->
    <section class="section latest-posts" id="latest-posts">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">📝</span>
          最新文章
        </h2>
        <p class="section-subtitle">深度教程与实战指南</p>

        <div class="latest-posts-grid">
          {latestPosts.map((post) => (
            <a
              href={`/zh-cn/tutorials/${post.data.category}/${post.slug}/`}
              class="latest-post-card"
            >
              <div class="post-card-header">
                {post.data.featured && <div class="post-badge">精选</div>}
                <div class="post-meta">
                  <span class="post-date">📅 {post.data.pubDate.toLocaleDateString("zh-CN")}</span>
                  <span class={`post-difficulty ${difficultyClassMap[post.data.difficulty]}`}>
                    {difficultyMap[post.data.difficulty]}难度
                  </span>
                  <span class="post-time">⏱️ {post.data.estimatedTime}</span>
                </div>
              </div>
              <h3 class="post-title">
                {post.data.title}
              </h3>
              <p class="post-description">
                {post.data.description}
              </p>
              <div class="post-tags">
                {post.data.tags.slice(0, 4).map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <div class="read-more">阅读全文 →</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 安装部署板块 -->
    <section class="section installation" id="installation">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">⚙️</span>
          <a
            href="/zh-cn/installation/"
            style="text-decoration: none; color: inherit;">安装部署</a
          >
        </h2>
        <p class="section-subtitle">在本地机器或云端运行 OpenClaw</p>

        <div class="grid-3">
          <!-- 本地安装 -->
          <div class="card">
            <div class="card-header">
              <div class="card-icon">💻</div>
              <h3>本地安装</h3>
            </div>
            <ul class="card-list">
              <li><a href="/zh-cn/installation/local-mac/">macOS 安装</a></li>
              <li><a href="/zh-cn/installation/local-linux/">Linux 安装</a></li>
              <li>
                <a href="/zh-cn/installation/local-windows/">Windows 安装</a>
              </li>
            </ul>
          </div>

          <!-- 云端部署 -->
          <div class="card">
            <div class="card-header">
              <div class="card-icon">☁️</div>
              <h3>云端部署</h3>
            </div>
            <ul class="card-list">
              <li><a href="/zh-cn/installation/cloud-aliyun/">阿里云</a></li>
              <li><a href="/zh-cn/installation/cloud-tencent/">腾讯云</a></li>
              <li><a href="/zh-cn/installation/cloud-volcano/">火山引擎</a></li>
            </ul>
          </div>

          <!-- 一键部署平台 -->
          <div class="card">
            <div class="card-header">
              <div class="card-icon">🚀</div>
              <h3>一键部署平台</h3>
            </div>
            <ul class="card-list">
              <li>
                <a href="/zh-cn/installation/one-click-deployment/"
                  >字节 ArkClaw</a
                >
              </li>
              <li>
                <a href="/zh-cn/installation/one-click-deployment/"
                  >腾讯 QClaw</a
                >
              </li>
              <li>
                <a href="/zh-cn/installation/one-click-deployment/"
                  >智谱 AutoClaw</a
                >
              </li>
              <li>
                <a href="/zh-cn/installation/one-click-deployment/"
                  >猎豹 EasyClaw</a
                >
              </li>
              <li>
                <a href="/zh-cn/installation/one-click-deployment/"
                  >腾讯 WorkBuddy</a
                >
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 教程栏目板块 -->
    <section class="section tutorials" id="tutorials">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">📚</span>
          教程栏目
        </h2>
        <p class="section-subtitle">循序渐进掌握 OpenClaw 的所有功能</p>

        <div class="tutorial-grid">
          <!-- 01 新手上路 -->
          <div class="tutorial-card" id="tutorials-01">
            <div class="tutorial-badge">01</div>
            <h3 class="tutorial-title">新手上路</h3>
            <p class="tutorial-description">开启你的 OpenClaw 之旅</p>
            <div class="tutorial-topics">
              <span class="topic">模型接入</span>
              <span class="topic">飞书</span>
              <span class="topic">微信</span>
              <span class="topic">QQ</span>
              <span class="topic">企业微信</span>
            </div>
            <a href="/zh-cn/tutorials/getting-started/" class="tutorial-link"
              >查看教程 →</a
            >
          </div>

          <!-- 02 初始化小龙虾 -->
          <div class="tutorial-card" id="tutorials-02">
            <div class="tutorial-badge">02</div>
            <h3 class="tutorial-title">初始化小龙虾</h3>
            <p class="tutorial-description">配置你的 OpenClaw 实例</p>
            <div class="tutorial-topics">
              <span class="topic">AGENTS.md</span>
              <span class="topic">USER.md</span>
              <span class="topic">SOUL.md</span>
            </div>
            <a href="/zh-cn/tutorials/initialization/" class="tutorial-link"
              >查看教程 →</a
            >
          </div>

          <!-- 03 小龙虾的眼睛 -->
          <div class="tutorial-card" id="tutorials-03">
            <div class="tutorial-badge">03</div>
            <h3 class="tutorial-title">小龙虾的眼睛</h3>
            <p class="tutorial-description">视觉能力与图像理解</p>
            <div class="tutorial-topics">
              <span class="topic">视觉能力</span>
              <span class="topic">图像处理</span>
              <span class="topic">视频理解</span>
            </div>
            <a href="/zh-cn/tutorials/claw-eyes/" class="tutorial-link"
              >查看教程 →</a
            >
          </div>

          <!-- 04 小龙虾的手脚 -->
          <div class="tutorial-card" id="tutorials-04">
            <div class="tutorial-badge">04</div>
            <h3 class="tutorial-title">小龙虾的手脚</h3>
            <p class="tutorial-description">使用工具扩展功能</p>
            <div class="tutorial-topics">
              <span class="topic">工具调用</span>
              <span class="topic">API 集成</span>
              <span class="topic">自动化</span>
            </div>
            <a href="/zh-cn/tutorials/claw-hands/" class="tutorial-link"
              >查看教程 →</a
            >
          </div>

          <!-- 05 小龙虾的大脑 -->
          <div class="tutorial-card" id="tutorials-05">
            <div class="tutorial-badge">05</div>
            <h3 class="tutorial-title">小龙虾的大脑</h3>
            <p class="tutorial-description">记忆系统与协作机制</p>
            <div class="tutorial-topics">
              <span class="topic">记忆系统</span>
              <span class="topic">协作机制</span>
              <span class="topic">上下文管理</span>
            </div>
            <a href="/zh-cn/tutorials/claw-brain/" class="tutorial-link"
              >查看教程 →</a
            >
          </div>

          <!-- 06 多 Agents 能力 -->
          <div class="tutorial-card" id="tutorials-06">
            <div class="tutorial-badge">06</div>
            <h3 class="tutorial-title">多 Agents 能力</h3>
            <p class="tutorial-description">高级多智能体功能</p>
            <div class="tutorial-topics">
              <span class="topic">基础入门</span>
              <span class="topic">进阶技巧</span>
            </div>
            <a href="/zh-cn/tutorials/multi-agents/" class="tutorial-link"
              >查看教程 →</a
            >
          </div>
        </div>
      </div>
    </section>

    <!-- 疑难解答板块 -->
    <section class="section troubleshooting" id="troubleshooting">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">🔧</span>
          疑难解答
        </h2>
        <p class="section-subtitle">快速解决常见的 OpenClaw 问题</p>

        <div class="troubleshooting-grid">
          <!-- 搜索框 -->
          <div class="search-card">
            <div class="search-icon">🔍</div>
            <h3>搜索 GitHub 问题</h3>
            <p>从社区找到解决方案</p>
            <a href="/bugs/" class="search-button">搜索问题</a>
          </div>

          <!-- 常见问题 -->
          <div class="issues-list">
            <h3>常见问题</h3>
            <div class="issue-items">
              <a href="/zh-cn/bugs/?q=端口已被占用" class="issue-item">1. 端口已被占用</a>
              <a href="/zh-cn/bugs/?q=权限被拒绝" class="issue-item">2. 权限被拒绝错误</a>
              <a href="/zh-cn/bugs/?q=网关连接失败" class="issue-item">3. 网关连接失败</a>
              <a href="/zh-cn/bugs/?q=API+密钥" class="issue-item">4. 模型 API 密钥问题</a>
              <a href="/zh-cn/bugs/?q=Node.js+版本" class="issue-item">5. Node.js 版本兼容性</a>
              <a href="/zh-cn/bugs/?q=内存分配" class="issue-item">6. 内存分配问题</a>
              <a href="/zh-cn/bugs/?q=文件路径" class="issue-item">7. 文件路径错误</a>
              <a href="/zh-cn/bugs/?q=网络超时" class="issue-item">8. 网络超时问题</a>
              <a href="/zh-cn/bugs/?q=配置文件" class="issue-item">9. 配置文件错误</a>
              <a href="/zh-cn/bugs/?q=依赖冲突" class="issue-item">10. 依赖冲突</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 成本计算器板块 -->
    <section class="section cost-calculator" id="cost-calculator">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">💰</span>
          成本计算器
        </h2>
        <p class="section-subtitle">估算你的 OpenClaw 运行成本（即将推出）</p>

        <div class="calculator-preview">
          <div class="preview-content">
            <div class="preview-icon">🧮</div>
            <h3>成本计算器开发中</h3>
            <p>我们正在开发基于使用模式和 AI 模型选择的成本计算工具，敬请期待</p>
            <ul class="feature-list">
              <li>✓ 模型 API 成本对比</li>
              <li>✓ 服务器托管估算</li>
              <li>✓ 基于使用量的计算</li>
            </ul>
            <button class="preview-button" disabled style="opacity: 0.6; cursor: not-allowed;">
              即将上线
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- 社区与资源板块 -->
    <section class="section community" id="community">
      <div class="container">
        <h2 class="section-title">
          <span class="section-icon">👥</span>
          社区与资源
        </h2>
        <p class="section-subtitle">加入社区，获取开发资源，共同成长</p>

        <div class="community-grid-enhanced">
          <!-- 社区交流 -->
          <div class="community-card-enhanced">
            <div class="card-header-enhanced">
              <div class="card-icon-large">💬</div>
              <h3>社区交流</h3>
              <p class="card-desc">与全球开发者交流经验</p>
            </div>
            <ul class="link-list-enhanced">
              <li>
                <a
                  href="https://github.com/openclaw/openclaw/issues"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="link-icon">💬</span>
                  <span class="link-content">
                    <span class="link-title">GitHub Issues</span>
                    <span class="link-desc">问题讨论与反馈</span>
                  </span>
                </a>
              </li>
              <li>
                <a
                  href="https://discord.com/invite/openclaw"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="link-icon">🎮</span>
                  <span class="link-content">
                    <span class="link-title">Discord 社区</span>
                    <span class="link-desc">实时聊天与协作</span>
                  </span>
                </a>
              </li>

              <li>
                <a
                  href="https://github.com/openclaw/openclaw"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="link-icon">🐙</span>
                  <span class="link-content">
                    <span class="link-title">GitHub 仓库</span>
                    <span class="link-desc">源码与 Issue 追踪</span>
                  </span>
                </a>
              </li>
            </ul>
          </div>

          <!-- 学习资源 -->
          <div class="community-card-enhanced">
            <div class="card-header-enhanced">
              <div class="card-icon-large">📚</div>
              <h3>学习资源</h3>
              <p class="card-desc">官方文档与学习材料</p>
            </div>
            <ul class="link-list-enhanced">
              <li>
                <a
                  href="https://docs.openclaw.ai/zh-CN"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="link-icon">📖</span>
                  <span class="link-content">
                    <span class="link-title">官方中文文档</span>
                    <span class="link-desc">快速开始与配置指南</span>
                  </span>
                </a>
              </li>

              <li>
                <a
                  href="https://clawhub.ai/matrixy/agent-browser-clawdbot"
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                >
                  <span class="link-icon">🌍</span>
                  <span class="link-content">
                    <span class="link-title">Agent Browser</span>
                    <span class="link-desc">强大的在线访问能力</span>
                  </span>
                </a>
              </li>

              <li>
                <a
                  href="https://clawhub.ai/pskoett/self-improving-agent"
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                >
                  <span class="link-icon">👦</span>
                  <span class="link-content">
                    <span class="link-title">Self Improving Agent</span>
                    <span class="link-desc">会自我进化的龙虾</span>
                  </span>
                </a>
              </li>
            </ul>
          </div>

          <!-- 相关项目 -->
          <div class="community-card-enhanced">
            <div class="card-header-enhanced">
              <div class="card-icon-large">🔗</div>
              <h3>相关项目</h3>
              <p class="card-desc">生态工具与扩展</p>
            </div>
            <ul class="link-list-enhanced">
              <li>
                <a
                  href="https://clawhub.ai/skills"
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                >
                  <span class="link-icon">🔧</span>
                  <span class="link-content">
                    <span class="link-title">ClawHub Skills </span>
                    <span class="link-desc">官方技能中心</span>
                  </span>
                </a>
              </li>
              <li>
                <a
                  href="https://clawhub.ai/plugins"
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                >
                  <span class="link-icon">🔌</span>
                  <span class="link-content">
                    <span class="link-title">ClawHub Plugins</span>
                    <span class="link-desc">官方插件中心</span>
                  </span>
                </a>
              </li>
              <li>
                <a
                  href="https://pinchbench.com/"
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                >
                  <span class="link-icon">📈</span>
                  <span class="link-content">
                    <span class="link-title">PinchBench</span>
                    <span class="link-desc">openclaw 最佳模型榜单</span>
                  </span>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 页脚 -->
    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div class="disclaimer">
            <strong>免责声明：</strong>本网站是独立的教程资源，与 OpenClaw
            官方项目无关联。
          </div>
          <div class="footer-links">
            <span>© 2026 OpenClaw Tutorial</span>
          </div>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style>
  /* ========================================
     钛金属深色拟物化设计风格
     ======================================== */

  /* 基础样式 - 深蓝黑色渐变背景 */
  .homepage {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(113, 113, 122, 0.03) 2px,
        rgba(113, 113, 122, 0.03) 4px
      ),
      linear-gradient(135deg, #0a0e27 0%, #1a1f3a 50%, #0a0e27 100%);
    background-attachment: fixed;
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section {
    padding: 5rem 0;
  }

  /* 标题 - 钛金属发光效果 */
  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1rem;
    color: #e4e4e7;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-shadow:
      0 0 8px rgba(228, 228, 231, 0.4),
      0 0 16px rgba(228, 228, 231, 0.3),
      0 0 24px rgba(228, 228, 231, 0.2);
    letter-spacing: 0.05em;
  }

  .section-icon {
    font-size: 2.5rem;
    filter: drop-shadow(0 0 8px rgba(212, 212, 216, 0.5));
  }

  .section-subtitle {
    text-align: center;
    color: #a1a1aa;
    font-size: 1.125rem;
    margin-bottom: 3rem;
    font-style: italic;
    text-shadow: 0 0 8px rgba(161, 161, 170, 0.5);
  }

  /* Hero 区域 - 深蓝黑色金属质感 */
  .hero {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.05) 1px,
        rgba(113, 113, 122, 0.05) 2px
      ),
      linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
    position: relative;
    color: #e4e4e7;
    padding: 8rem 0 6rem;
    text-align: center;
    border-bottom: 3px solid #d4d4d8;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.5),
      0 0 30px rgba(228, 228, 231, 0.2);
  }

  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(228, 228, 231, 0.015) 10px,
      rgba(228, 228, 231, 0.015) 20px
    );
    pointer-events: none;
  }

  .hero-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    letter-spacing: 0.02em;
  }

  /* 小龙虾主题渐变 - 橘红色调 */
  .title-highlight {
    background: linear-gradient(
      90deg,
      #dc2626 0%,
      #ef4444 15%,
      #f97316 30%,
      #fb923c 45%,
      #fbbf24 55%,
      #f97316 70%,
      #ef4444 85%,
      #dc2626 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: claw-gradient-flow 3s linear infinite;
  }

  @keyframes claw-gradient-flow {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    margin-bottom: 1rem;
    opacity: 0.95;
    text-shadow:
      0 0 8px rgba(212, 212, 216, 0.4),
      0 2px 4px rgba(0, 0, 0, 0.5);
  }

  /* 苹果风格多彩渐变统计文字 */
  .hero-stats {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: #a1a1aa;
    margin: 0 0 2rem 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .stats-count {
    font-weight: 800;
    font-size: 1.5em;
    padding: 0 0.1em;
    background: linear-gradient(
      90deg,
      #ff6b6b 0%,
      #ffa502 20%,
      #ffd43b 35%,
      #51cf66 50%,
      #339af0 65%,
      #845ef7 80%,
      #f06595 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradient-flow 4s linear infinite;
  }

  @keyframes gradient-flow {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* 钛金属拟物化按钮 */
  .cta-button {
    padding: 1rem 2.5rem;
    font-weight: 600;
    text-decoration: none;
    font-size: 1rem;
    position: relative;
    border: none;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .cta-button.primary {
    background: linear-gradient(180deg, #71717a 0%, #52525b 50%, #3f3f46 100%);
    color: #e4e4e7;
    border-radius: 8px;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.2),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 15px rgba(228, 228, 231, 0.3),
      0 4px 8px rgba(0, 0, 0, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .cta-button.secondary {
    background: linear-gradient(
      180deg,
      rgba(113, 113, 122, 0.3) 0%,
      rgba(63, 63, 70, 0.3) 100%
    );
    color: #e4e4e7;
    border-radius: 8px;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.1),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 12px rgba(228, 228, 231, 0.2);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .cta-button.primary:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.2),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 22px rgba(228, 228, 231, 0.4),
      0 6px 12px rgba(0, 0, 0, 0.4);
  }

  .cta-button.secondary:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.1),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 18px rgba(228, 228, 231, 0.3);
  }

  .cta-button.primary:active {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.4),
      inset 0 -1px 2px rgba(255, 255, 255, 0.1),
      0 0 12px rgba(228, 228, 231, 0.3);
  }

  /* 网格布局 */
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  /* 钛金属拟物化卡片 */
  .card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(228, 228, 231, 0.2),
      0 6px 12px rgba(0, 0, 0, 0.3);
    transition: all 0.2s ease;
  }

  .card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(228, 228, 231, 0.4) 0%,
      transparent 50%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 22px rgba(228, 228, 231, 0.3),
      0 8px 16px rgba(0, 0, 0, 0.4);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #d4d4d8;
  }

  .card-icon {
    font-size: 2.5rem;
    filter: drop-shadow(0 0 8px rgba(212, 212, 216, 0.6));
  }

  .card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #e4e4e7;
    margin: 0;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .card-list {
    list-style: none;
    padding: 0;
  }

  .card-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid #d4d4d8;
  }

  .card-list li:last-child {
    border-bottom: none;
  }

  .card-list a {
    color: #a1a1aa;
    text-decoration: none;
    transition: all 0.2s;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .card-list a:hover {
    color: #e4e4e7;
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.6);
  }

  /* 最新文章板块 */
  .latest-posts-grid {
    display: grid;
    gap: 2rem;
  }

  /* 最新文章卡片 - 钛金属质感 */
  .latest-post-card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2.5rem;
    position: relative;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 18px rgba(228, 228, 231, 0.2),
      0 8px 16px rgba(0, 0, 0, 0.3);
    text-decoration: none;
    transition: all 0.2s ease;
    display: block;
  }

  .latest-post-card::before {
    content: "";
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    bottom: 12px;
    border: 2px dashed #e4e4e7;
    border-radius: 8px;
    pointer-events: none;
    opacity: 0.6;
  }

  .latest-post-card:hover {
    transform: translateY(-3px);
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 30px rgba(228, 228, 231, 0.35),
      0 12px 24px rgba(0, 0, 0, 0.4);
  }

  .post-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  /* 精选徽章 */
  .post-badge {
    background: repeating-linear-gradient(
      90deg,
      #d4d4d8,
      #e4e4e7 2px,
      #d4d4d8 4px
    );
    color: #18181b;
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.875rem;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.4),
      0 0 12px rgba(228, 228, 231, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.4);
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.2);
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    color: #a1a1aa;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .post-date,
  .post-time {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .post-difficulty {
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .post-difficulty.intermediate {
    background: linear-gradient(
      180deg,
      rgba(228, 228, 231, 0.2) 0%,
      rgba(212, 212, 216, 0.15) 100%
    );
    color: #e4e4e7;
    border: 1px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 8px rgba(228, 228, 231, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.5);
  }

  .post-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e4e4e7;
    margin: 0 0 1rem 0;
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.5);
    line-height: 1.4;
  }

  .post-description {
    color: #a1a1aa;
    margin-bottom: 1.5rem;
    font-size: 1rem;
    line-height: 1.6;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    background: linear-gradient(
      180deg,
      rgba(228, 228, 231, 0.2) 0%,
      rgba(212, 212, 216, 0.15) 100%
    );
    color: #e4e4e7;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    font-size: 0.875rem;
    border: 1px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 8px rgba(228, 228, 231, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.5);
  }

  .read-more {
    color: #e4e4e7;
    font-weight: 600;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
    font-size: 1rem;
  }

  .latest-post-card:hover .read-more {
    color: #d4d4d8;
    text-shadow: 0 0 12px rgba(212, 212, 216, 0.6);
  }

  /* 教程网格 */
  .tutorial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  /* 教程卡片 - 钛金属文件夹效果 */
  .tutorial-card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 18px rgba(228, 228, 231, 0.2),
      0 8px 16px rgba(0, 0, 0, 0.3);
    transition: all 0.2s ease;
  }

  .tutorial-card::before {
    content: "";
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    bottom: 12px;
    border: 2px dashed #e4e4e7;
    border-radius: 8px;
    pointer-events: none;
    opacity: 0.6;
  }

  .tutorial-card:hover {
    transform: translateY(-3px);
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 30px rgba(228, 228, 231, 0.35),
      0 12px 24px rgba(0, 0, 0, 0.4);
  }

  /* 银色金属徽章 */
  .tutorial-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: repeating-linear-gradient(
      90deg,
      #d4d4d8,
      #e4e4e7 2px,
      #d4d4d8 4px
    );
    color: #18181b;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    border: 3px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(228, 228, 231, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.4);
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.2);
  }

  .tutorial-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e4e4e7;
    margin: 0 0 0.5rem 0;
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.5);
  }

  .tutorial-description {
    color: #a1a1aa;
    margin-bottom: 1.5rem;
    font-style: italic;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .tutorial-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  /* 标签 - 银色光晕效果 */
  .topic {
    background: linear-gradient(
      180deg,
      rgba(228, 228, 231, 0.2) 0%,
      rgba(212, 212, 216, 0.15) 100%
    );
    color: #e4e4e7;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    font-size: 0.875rem;
    border: 1px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 8px rgba(228, 228, 231, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.5);
  }

  .tutorial-link {
    color: #e4e4e7;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .tutorial-link:hover {
    color: #d4d4d8;
    text-shadow: 0 0 12px rgba(212, 212, 216, 0.6);
    text-decoration: underline;
  }

  /* 疑难解答板块 */
  .troubleshooting-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
  }

  /* 搜索卡片 - 钛金属质感 */
  .search-card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.15) 1px,
        rgba(113, 113, 122, 0.15) 2px
      ),
      linear-gradient(135deg, #71717a 0%, #52525b 50%, #3f3f46 100%);
    color: #e4e4e7;
    border-radius: 12px;
    padding: 2.5rem;
    text-align: center;
    border: 3px solid #e4e4e7;
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.5),
      0 0 22px rgba(228, 228, 231, 0.35),
      0 8px 16px rgba(0, 0, 0, 0.4);
  }

  .search-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 12px rgba(212, 212, 216, 0.6));
  }

  .search-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 0 10px rgba(228, 228, 231, 0.5);
  }

  .search-card p {
    margin-bottom: 1.5rem;
    opacity: 0.9;
    text-shadow: 0 0 8px rgba(161, 161, 170, 0.5);
  }

  .search-button {
    display: inline-block;
    background: linear-gradient(180deg, #a1a1aa 0%, #71717a 100%);
    color: #e4e4e7;
    padding: 0.85rem 2.25rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 15px rgba(228, 228, 231, 0.4),
      0 4px 8px rgba(0, 0, 0, 0.3);
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.6);
    transition: all 0.15s ease;
  }

  .search-button:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 22px rgba(228, 228, 231, 0.6),
      0 6px 12px rgba(0, 0, 0, 0.4);
  }

  .search-button:active {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.4),
      0 0 12px rgba(228, 228, 231, 0.4);
  }

  /* 问题列表 - 深色便签效果 */
  .issues-list {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.08) 1px,
        rgba(113, 113, 122, 0.08) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2rem;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 6px 12px rgba(0, 0, 0, 0.3);
  }

  .issues-list h3 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    color: #e4e4e7;
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.4);
  }

  .issue-items {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 0.75rem;
  }

  .issue-item {
    display: block;
    padding: 0.85rem 1.15rem;
    background: linear-gradient(
      180deg,
      rgba(39, 39, 42, 0.8) 0%,
      rgba(24, 24, 27, 0.8) 100%
    );
    border-radius: 6px;
    color: #a1a1aa;
    text-decoration: none;
    transition: all 0.2s;
    font-size: 0.9375rem;
    border: 1px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 2px 4px rgba(0, 0, 0, 0.2);
  }

  .issue-item:hover {
    background: linear-gradient(
      180deg,
      rgba(161, 161, 170, 0.2) 0%,
      rgba(113, 113, 122, 0.15) 100%
    );
    color: #e4e4e7;
    transform: translateX(4px);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 12px rgba(228, 228, 231, 0.4);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.5);
  }

  /* 成本计算器 - 钛金属卡片 */
  .calculator-preview {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 0 18px rgba(228, 228, 231, 0.2),
      0 8px 16px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    border: 2px solid #d4d4d8;
  }

  .preview-content {
    padding: 3rem;
    text-align: center;
  }

  .preview-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 12px rgba(212, 212, 216, 0.6));
  }

  .preview-content h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: #e4e4e7;
    text-shadow: 0 0 12px rgba(228, 228, 231, 0.5);
  }

  .preview-content p {
    color: #a1a1aa;
    margin-bottom: 1.5rem;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
    display: inline-block;
    text-align: left;
  }

  .feature-list li {
    padding: 0.6rem 0;
    color: #e4e4e7;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .preview-button {
    display: inline-block;
    background: linear-gradient(180deg, #a1a1aa 0%, #71717a 100%);
    color: #e4e4e7;
    padding: 1rem 2.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 18px rgba(228, 228, 231, 0.4),
      0 4px 8px rgba(0, 0, 0, 0.3);
