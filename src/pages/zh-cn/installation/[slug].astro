---
import { getCollection } from 'astro:content';
import TutorialLayout from '../../../layouts/TutorialLayout.astro';

export async function getStaticPaths() {
  // 获取所有中文文章
  const allPosts = await getCollection('posts-zh-cn');

  // 筛选 category 为 installation 的已发布文章
  const installationPosts = allPosts
    .filter(post => post.data.category === 'installation' && post.data.status !== 'draft')
    .map(post => ({
      params: {
        slug: post.slug,
      },
      props: { post },
    }));

  return installationPosts;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<TutorialLayout post={post}>
  <Content />
</TutorialLayout>
