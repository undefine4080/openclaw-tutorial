---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="Bug 问题库 - OpenClaw 已解决 Issue 快速搜索与解决方案"
  description="OpenClaw Bug 问题库：快速搜索数百个已解决的 GitHub Issue。涵盖安装错误、配置问题、API 故障、性能问题等。提供关键词搜索、标签过滤、状态筛选，一键跳转到原始 Issue。"
>
  <main class="bugs-page">
    <!-- 页面标题 -->
    <div class="bugs-header">
      <h1>🐛 Bug 问题库</h1>
      <p class="subtitle">快速搜索已解决的 Issue，一键跳转到 GitHub 查看详情</p>
      <div class="stats-bar">
        <div class="stat">
          <span class="stat-number" id="total-issues">-</span>
          <span class="stat-label">已关闭 Issue</span>
        </div>
        <div class="stat">
          <span class="stat-number" id="recent-week">-</span>
          <span class="stat-label">本周新增</span>
        </div>
      </div>
    </div>

    <!-- 搜索框 -->
    <div class="search-section">
      <div class="search-box">
        <input
          type="text"
          id="search-input"
          placeholder="输入关键词搜索 Issue（支持中英文、错误代码、标签等）"
          class="search-input"
          autocomplete="off"
          autofocus
        />
        <div id="search-spinner" class="search-spinner hidden">
          <svg class="spinner" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
      </div>

      <!-- 快速筛选 -->
      <div class="quick-filters">
        <span class="filter-label">快速筛选：</span>
        <button class="filter-tag" data-filter="bug">🐛 bug</button>
        <button class="filter-tag" data-filter="installation">📦 installation</button>
        <button class="filter-tag" data-filter="regression">⚠️ regression</button>
        <button class="filter-tag" data-filter="documentation">📚 documentation</button>
        <button class="filter-tag" data-filter="help wanted">🆘 help wanted</button>
      </div>
    </div>

    <!-- 搜索结果统计 -->
    <div id="results-info" class="results-info hidden">
      <p>找到 <span id="result-count" class="result-count">0</span> 个相关 Issue</p>
    </div>

    <!-- Issue 列表 -->
    <div id="issues-container" class="issues-list">
      <div class="loading">
        <p>正在加载 Issue 数据...</p>
      </div>
    </div>

    <!-- 加载更多 -->
    <div id="load-more-container" class="load-more-container hidden">
      <button id="load-more-btn" class="btn btn-secondary">
        加载更多
      </button>
    </div>

    <!-- 空状态 -->
    <div id="empty-state" class="empty-state hidden">
      <div class="empty-icon">🔍</div>
      <h3>没有找到相关 Issue</h3>
      <p>试试其他关键词，或者直接去 <a href="https://github.com/openclaw/openclaw/issues" target="_blank" rel="noopener noreferrer">GitHub Issues</a> 查看</p>
    </div>
  </main>
</Layout>

<script>
  // 全局变量
  let allIssues: any[] = [];
  let filteredIssues: any[] = [];
  let currentPage = 1;
  const perPage = 20;
  let searchTimeout: ReturnType<typeof setTimeout> | null = null;

  // DOM 元素
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchSpinner = document.getElementById('search-spinner') as HTMLDivElement;
  const issuesContainer = document.getElementById('issues-container') as HTMLDivElement;
  const resultsInfo = document.getElementById('results-info') as HTMLDivElement;
  const resultCount = document.getElementById('result-count') as HTMLSpanElement;
  const loadMoreContainer = document.getElementById('load-more-container') as HTMLDivElement;
  const loadMoreBtn = document.getElementById('load-more-btn') as HTMLButtonElement;
  const emptyState = document.getElementById('empty-state') as HTMLDivElement;
  const totalIssuesEl = document.getElementById('total-issues') as HTMLSpanElement;
  const recentWeekEl = document.getElementById('recent-week') as HTMLSpanElement;

  /**
   * 加载 Issue 数据
   */
  async function loadIssues() {
    try {
      const response = await fetch('/data/issues/issues-search-index.json');
      const data = await response.json();

      allIssues = data.index;
      filteredIssues = allIssues;

      // 更新统计信息
      totalIssuesEl.textContent = data.meta.total_count.toLocaleString();

      // 计算最近 7 天的数量
      const weekAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;
      const recentCount = allIssues.filter((issue: any) => {
        return new Date(issue.closed_at).getTime() > weekAgo;
      }).length;
      recentWeekEl.textContent = recentCount.toString();

      // 初始显示所有 issues
      renderIssues();

    } catch (error) {
      console.error('加载 Issue 数据失败:', error);
      issuesContainer.innerHTML = `
        <div class="error-state">
          <div class="error-icon">❌</div>
          <h3>加载失败</h3>
          <p>请确保已运行 <code>npm run collect-issues</code> 和 <code>npm run generate-search-index</code></p>
        </div>
      `;
    }
  }

  /**
   * 搜索 Issues
   */
  function searchIssues(query: string) {
    if (!query || query.trim() === '') {
      filteredIssues = allIssues;
    } else {
      const searchTerms = query.toLowerCase().split(/\s+/).filter(term => term.length > 0);

      filteredIssues = allIssues.filter((issue: any) => {
        const title = issue.title.toLowerCase();
        const shortDesc = issue.short_desc.toLowerCase();
        const labels = issue.labels.join(' ').toLowerCase();
        const searchTermsStr = issue.search_terms.join(' ').toLowerCase();

        // 检查是否匹配所有搜索词
        return searchTerms.every(term => {
          return title.includes(term) ||
                 shortDesc.includes(term) ||
                 labels.includes(term) ||
                 searchTermsStr.includes(term) ||
                 issue.number.toString() === term;  // 支持按编号搜索
        });
      });
    }

    currentPage = 1;
    renderIssues();
  }

  /**
   * 渲染 Issues 列表
   */
  function renderIssues(append: boolean = false) {
    const start = 0;
    const end = currentPage * perPage;
    const visibleIssues = filteredIssues.slice(start, end);

    if (!append) {
      issuesContainer.innerHTML = '';
    }

    if (filteredIssues.length === 0) {
      // 显示空状态
      emptyState.classList.remove('hidden');
      resultsInfo.classList.add('hidden');
      loadMoreContainer.classList.add('hidden');
      return;
    }

    emptyState.classList.add('hidden');
    resultsInfo.classList.remove('hidden');
    resultCount.textContent = filteredIssues.length.toLocaleString();

    // 获取当前搜索词
    const searchQuery = searchInput.value.trim();
    const searchTerms = searchQuery ? searchQuery.toLowerCase().split(/\s+/).filter(term => term.length > 0) : [];

    // 渲染当前页的 issues
    const startIndex = append ? (currentPage - 1) * perPage : 0;

    visibleIssues.slice(startIndex).forEach((issue: any, index: number) => {
      const issueCard = createIssueCard(issue, startIndex + index + 1);
      issuesContainer.appendChild(issueCard);
    });

    // 更新加载更多按钮
    if (end >= filteredIssues.length) {
      loadMoreContainer.classList.add('hidden');
    } else {
      loadMoreContainer.classList.remove('hidden');
    }
  }

  /**
   * 高亮搜索关键词
   */
  function highlightText(text: string, searchTerms: string[]): string {
    if (!searchTerms || searchTerms.length === 0) {
      return escapeHtml(text);
    }

    let escapedText = escapeHtml(text);

    // 对每个搜索词进行高亮
    searchTerms.forEach(term => {
      if (term.length > 0) {
        const regex = new RegExp(`(${escapeRegex(term)})`, 'gi');
        escapedText = escapedText.replace(regex, '<mark class="highlight">$1</mark>');
      }
    });

    return escapedText;
  }

  /**
   * 转义正则表达式特殊字符
   */
  function escapeRegex(string: string): string {
    return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  /**
   * 创建 Issue 卡片
   */
  function createIssueCard(issue: any, index: number): HTMLElement {
    const card = document.createElement('div');
    card.className = 'issue-card';

    // 获取当前搜索词
    const searchValue = searchInput.value.trim().toLowerCase();
    const searchTerms = searchValue ? searchValue.split(/\s+/).filter(t => t.length > 0) : [];

    const labelsHtml = issue.labels
      .slice(0, 3)
      .map((label: string) => `<span class="label">${label}</span>`)
      .join('');

    const closedDate = new Date(issue.closed_at).toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    });

    card.innerHTML = `
      <div class="issue-header">
        <div class="issue-number">#${issue.number}</div>
        <h3 class="issue-title">${highlightText(issue.title, searchTerms)}</h3>
      </div>

      <div class="issue-labels">${labelsHtml}</div>

      <p class="issue-desc">${highlightText(issue.short_desc, searchTerms)}${issue.short_desc.length >= 200 ? '...' : ''}</p>

      <div class="issue-footer">
        <span class="issue-date">✅ 已关闭于 ${closedDate}</span>
        <a href="${issue.url}" target="_blank" rel="noopener noreferrer" class="issue-link">
          查看详情 →
        </a>
      </div>
    `;

    return card;
  }

  /**
   * HTML 转义
   */
  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  /**
   * 事件绑定
   */

  // 搜索框输入
  searchInput.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.trim();

    if (searchTimeout) clearTimeout(searchTimeout);

    if (query.length === 0) {
      searchIssues('');
      return;
    }

    searchSpinner.classList.remove('hidden');

    searchTimeout = setTimeout(() => {
      searchIssues(query);
      searchSpinner.classList.add('hidden');
    }, 300);
  });

  // 快速筛选标签
  document.querySelectorAll('.filter-tag').forEach(tag => {
    tag.addEventListener('click', () => {
      const filter = tag.getAttribute('data-filter') || '';
      searchInput.value = filter;
      searchIssues(filter);
    });
  });

  // 加载更多
  loadMoreBtn.addEventListener('click', () => {
    currentPage++;
    renderIssues(true);
  });

  // 页面加载时执行
  document.addEventListener('DOMContentLoaded', loadIssues);
</script>

<style is:global>
  /* ========================================
     钛金属深色拟物化设计风格
     ======================================== */

  .bugs-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 2rem;
    min-height: 100vh;
    color: #e4e4e7;
  }

  /* 页面标题 */
  .bugs-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .bugs-header h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: #e4e4e7;
    text-shadow:
      0 0 15px rgba(228, 228, 231, 0.5),
      0 0 30px rgba(228, 228, 231, 0.3),
      0 4px 8px rgba(0, 0, 0, 0.5);
    letter-spacing: 0.02em;
  }

  .subtitle {
    font-size: 1.25rem;
    color: #a1a1aa;
    font-style: italic;
    text-shadow: 0 0 8px rgba(161, 161, 170, 0.5);
    margin-bottom: 2rem;
  }

  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-top: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: #60a5fa;
    text-shadow: 0 0 12px rgba(96, 165, 250, 0.6);
  }

  .stat-label {
    font-size: 0.875rem;
    color: #a1a1aa;
    margin-top: 0.25rem;
  }

  /* 搜索区域 */
  .search-section {
    margin-bottom: 2.5rem;
  }

  .search-box {
    position: relative;
    margin-bottom: 1.25rem;
  }

  .search-input {
    width: 100%;
    padding: 1rem 1.5rem;
    padding-right: 3rem;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border: 2px solid #d4d4d8;
    border-radius: 12px;
    font-size: 1rem;
    color: #e4e4e7;
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(228, 228, 231, 0.2),
      0 6px 12px rgba(0, 0, 0, 0.3);
  }

  .search-input::placeholder {
    color: #71717a;
  }

  .search-input:focus {
    outline: none;
    border-color: #60a5fa;
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(96, 165, 250, 0.4),
      0 6px 12px rgba(0, 0, 0, 0.3);
  }

  .search-spinner {
    position: absolute;
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.5rem;
    height: 1.5rem;
    color: #60a5fa;
  }

  .spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .hidden {
    display: none !important;
  }

  /* 快速筛选 */
  .quick-filters {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .filter-label {
    color: #a1a1aa;
    font-size: 0.875rem;
    margin-right: 0.5rem;
  }

  .filter-tag {
    padding: 0.5rem 1rem;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, rgba(39, 39, 42, 0.8) 0%, rgba(24, 24, 27, 0.8) 100%);
    border: 1px solid #a1a1aa;
    border-radius: 9999px;
    font-size: 0.875rem;
    color: #a1a1aa;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 0 8px rgba(228, 228, 231, 0.2);
  }

  .filter-tag:hover {
    border-color: #d4d4d8;
    color: #e4e4e7;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 12px rgba(228, 228, 231, 0.3);
  }

  /* 结果统计 - 钛金属便签效果 */
  .results-info {
    margin-bottom: 1.5rem;
    padding: 1rem 1.25rem;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-left: 4px solid #d4d4d8;
    border-radius: 8px;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 12px rgba(228, 228, 231, 0.2),
      0 4px 8px rgba(0, 0, 0, 0.3);
  }

  .result-count {
    font-weight: 700;
    color: #e4e4e7;
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.5);
  }

  /* Issue 列表 */
  .issues-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .loading,
  .error-state,
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: #a1a1aa;
  }

  .error-icon,
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .error-state h3,
  .empty-state h3 {
    color: #e4e4e7;
    margin-bottom: 0.5rem;
  }

  .error-state code {
    background: rgba(248, 113, 113, 0.2);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-family: monospace;
    border: 1px solid #f87171;
  }

  .empty-state a {
    color: #60a5fa;
    text-decoration: underline;
  }

  /* Issue 卡片 - 钛金属文件夹效果 */
  .issue-card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 2.5rem;
    position: relative;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 18px rgba(228, 228, 231, 0.2),
      0 8px 16px rgba(0, 0, 0, 0.3);
    transition: all 0.2s ease;
  }

  .issue-card::before {
    content: '';
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    bottom: 12px;
    border: 2px dashed #e4e4e7;
    border-radius: 8px;
    pointer-events: none;
    opacity: 0.6;
  }

  .issue-card:hover {
    transform: translateY(-3px);
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.2),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 30px rgba(228, 228, 231, 0.35),
      0 12px 24px rgba(0, 0, 0, 0.4);
  }

  .issue-header {
    display: flex;
    align-items: start;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #d4d4d8;
  }

  .issue-number {
    background: repeating-linear-gradient(
      90deg,
      #d4d4d8,
      #e4e4e7 2px,
      #d4d4d8 4px
    );
    color: #18181b;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 700;
    border: 2px solid #d4d4d8;
    white-space: nowrap;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      inset 0 -1px 2px rgba(0, 0, 0, 0.4),
      0 0 12px rgba(228, 228, 231, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.4);
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.2);
  }

  .issue-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    color: #e4e4e7;
    flex: 1;
    line-height: 1.5;
    word-break: break-word;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .issue-labels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .label {
    background: linear-gradient(180deg, rgba(228, 228, 231, 0.2) 0%, rgba(212, 212, 216, 0.15) 100%);
    color: #e4e4e7;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    font-size: 0.875rem;
    border: 1px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 8px rgba(228, 228, 231, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.5);
  }

  .issue-desc {
    color: #a1a1aa;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .issue-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.25rem;
    border-top: 2px solid #d4d4d8;
    margin-top: 0.5rem;
  }


  /* 高亮关键词样式 - 钛金属发光效果 */
  mark.highlight {
    background: linear-gradient(
      180deg,
      rgba(228, 228, 231, 0.2) 0%,
      rgba(212, 212, 216, 0.15) 100%
    );
    color: #60a5fa;
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-weight: 600;
    border: 2px solid #60a5fa;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.8),
      inset 0 -1px 2px rgba(0, 0, 0, 0.4),
      0 0 12px rgba(96, 165, 250, 0.8),
      0 2px 6px rgba(0, 0, 0, 0.3);
    text-shadow: 0 0 8px rgba(96, 165, 250, 0.8);
    animation: highlight-pulse 2s ease-in-out infinite;
  }

  @keyframes highlight-pulse {
    0%,
    100% {
      box-shadow:
        inset 0 1px 2px rgba(255, 255, 255, 0.8),
        inset 0 -1px 2px rgba(0, 0, 0, 0.4),
        0 0 16px rgba(96, 165, 250, 0.8),
        0 3px 6px rgba(0, 0, 0, 0.3);
    }
  }

  html.light-mode mark.highlight {
    background: linear-gradient(
      180deg,
      rgba(251, 146, 60, 0.3) 0%,
      rgba(59, 130, 246, 0.2) 100%
    );
    color: #3b82f6;
    border-color: #3b82f6;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.8),
      inset 0 -1px 2px rgba(0, 0, 0, 0.15),
      0 0 12px rgba(59, 130, 246, 0.6),
      0 2px 6px rgba(0, 0, 0, 0.2);
    text-shadow: none;
    animation: highlight-pulse-light 2s ease-in-out infinite;
  }

  @keyframes highlight-pulse-light {
    0%,
    100% {
      box-shadow:
