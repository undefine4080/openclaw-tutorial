---
import Layout from '../../../layouts/Layout.astro';
import LangSwitch from '../../../components/LangSwitch.astro';
import { getCollection } from 'astro:content';

// 获取所有中文文章
const allPosts = await getCollection('posts-zh-cn');

// 按日期排序
const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
---

<Layout
  title="所有教程 - OpenClaw 完整中文教程索引与快速导航"
  description="浏览所有 OpenClaw 中文教程文章：安装部署、使用技巧、故障排除、最佳实践。按难度、标签、发布日期分类，快速找到你需要的内容。持续更新，累计数十篇深度教程。"
>
  <main class="post-list">
    <header class="page-header">
      <div class="lang-switcher-inline">
        <LangSwitch currentPath="/zh-cn/posts/" />
      </div>
      <h1>OpenClaw 教程与指南</h1>
      <p>完整的安装、配置和故障排除指南</p>
    </header>

    <div class="posts-grid">
      {sortedPosts.map((post) => (
        <article class="post-card">
          <div class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span class="difficulty">{post.data.difficulty}</span>
            <span class="time">{post.data.estimatedTime}</span>
          </div>
          <h2 class="post-title">
            <a href={`/zh-cn/posts/${post.id.replace('.md', '')}/`}>{post.data.title}</a>
          </h2>
          <p class="post-description">{post.data.description}</p>
          <div class="post-tags">
            {post.data.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <a href={`/zh-cn/posts/${post.id.replace('.md', '')}/`} class="read-more">阅读更多 →</a>
        </article>
      ))}
    </div>
  </main>
</Layout>

<style>
  .post-list {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .lang-switcher-inline {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    margin-bottom: 1rem;
    color: #1a1a1a;
  }

  .page-header p {
    font-size: 1.25rem;
    color: #666;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }

  .post-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .post-meta {
    display: flex;
    gap: 0.75rem;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .post-meta time {
    color: #666;
  }

  .difficulty {
    background: #dbeafe;
    color: #1e40af;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-weight: 500;
  }

  .time {
    background: #fef3c7;
    color: #92400e;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-weight: 500;
  }

  .post-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-title a {
    color: #1a1a1a;
    text-decoration: none;
    transition: color 0.2s;
  }

  .post-title a:hover {
    color: #0066cc;
  }

  .post-description {
    color: #666;
    line-height: 1.6;
    margin-bottom: 1rem;
    flex-grow: 1;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    background: #f3f4f6;
    color: #374151;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .read-more {
    color: #0066cc;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }

  .read-more:hover {
    color: #0052a3;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
