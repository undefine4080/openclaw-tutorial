---
const { currentPath } = Astro.props;

// 判断当前语言
const isZhCN = currentPath?.startsWith('/zh-cn');

// 导航菜单数据
const navData = isZhCN ? {
  logo: '🦞 OpenClaw Tutorial',
  tutorials: '教程',
  installation: '安装部署',
  troubleshooting: '疑难解答',
  costCalculator: '成本计算器',
  community: '社区',
  tutorialCategories: [
    { name: '01 新手上路', href: '#tutorials-01', topics: ['模型接入', '飞书', '微信', 'QQ', '企业微信'] },
    { name: '02 初始化小龙虾', href: '#tutorials-02', topics: ['AGENTS.md', 'USER.md', 'SOUL.md'] },
    { name: '03 小龙虾的眼睛', href: '#tutorials-03', topics: ['视觉能力', '图像处理', '视频理解'] },
    { name: '04 小龙虾的手脚', href: '#tutorials-04', topics: ['工具调用', 'API集成', '自动化'] },
    { name: '05 小龙虾的大脑', href: '#tutorials-05', topics: ['记忆系统', '协作机制', '上下文管理'] },
    { name: '06 必备技能包', href: '#tutorials-06', topics: ['新手必备', '开发者热门', '自媒体热门', '热门通用'] },
    { name: '07 多 Agents 能力', href: '#tutorials-07', topics: ['基础入门', '进阶技巧'] }
  ]
} : {
  logo: '🦞 OpenClaw Tutorial',
  tutorials: 'Tutorials',
  installation: 'Installation',
  troubleshooting: 'Troubleshooting',
  costCalculator: 'Cost Calculator',
  community: 'Community',
  tutorialCategories: [
    { name: '01 Getting Started', href: '#tutorials-01', topics: ['Model Integration', 'Feishu', 'WeChat', 'QQ', 'WeCom'] },
    { name: '02 Initialize OpenClaw', href: '#tutorials-02', topics: ['AGENTS.md', 'USER.md', 'SOUL.md'] },
    { name: '03 OpenClaw Vision', href: '#tutorials-03', topics: ['Visual Capability', 'Image Processing', 'Video Understanding'] },
    { name: '04 OpenClaw Tools', href: '#tutorials-04', topics: ['Tool Calling', 'API Integration', 'Automation'] },
    { name: '05 OpenClaw Brain', href: '#tutorials-05', topics: ['Memory System', 'Collaboration', 'Context Management'] },
    { name: '06 Essential Skills', href: '#tutorials-06', topics: ['Beginner Essentials', 'Dev Popular', 'Media Popular', 'General Popular'] },
    { name: '07 Multi-Agent', href: '#tutorials-07', topics: ['Basic', 'Advanced'] }
  ]
};

// 计算语言切换路径
const enPath = isZhCN ? currentPath.replace('/zh-cn', '') || '/' : currentPath || '/';
const zhPath = isZhCN ? currentPath : `/zh-cn${currentPath || ''}`.replace(/\/$/, '') || '/zh-cn/';
---

<nav class="navbar" id="navbar">
  <div class="nav-container">
    <!-- Logo -->
    <a href={isZhCN ? "/zh-cn/" : "/"} class="nav-logo">
      {navData.logo}
    </a>

    <!-- Desktop Menu -->
    <div class="nav-menu desktop">
      <!-- Tutorials with Dropdown -->
      <div class="nav-item dropdown">
        <button class="nav-link dropdown-toggle" aria-expanded="false">
          {navData.tutorials}
          <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="dropdown-menu">
          {navData.tutorialCategories.map((category) => (
            <div class="dropdown-item">
              <a href={category.href} class="dropdown-link">
                {category.name}
              </a>
              <div class="dropdown-topics">
                {category.topics.map(topic => (
                  <span class="topic-tag">{topic}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <a href="#installation" class="nav-link">{navData.installation}</a>
      <a href="#troubleshooting" class="nav-link">{navData.troubleshooting}</a>
      <a href="#cost-calculator" class="nav-link">{navData.costCalculator}</a>
      <a href="#community" class="nav-link">{navData.community}</a>

      <!-- Language Switcher -->
      <div class="lang-switcher">
        <a href={enPath} class:list={[!isZhCN && 'active']}>EN</a>
        <span class="divider">/</span>
        <a href={zhPath} class:list={[isZhCN && 'active']}>中文</a>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <button class="mobile-menu-btn" aria-label="Toggle menu" id="mobileMenuBtn">
      <span class="hamburger"></span>
      <span class="hamburger"></span>
      <span class="hamburger"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="nav-menu mobile" id="mobileMenu">
    <div class="mobile-dropdown">
      <button class="mobile-dropdown-toggle" data-dropdown="tutorials">
        {navData.tutorials}
        <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="mobile-dropdown-menu" id="tutorialsDropdown">
        {navData.tutorialCategories.map((category) => (
          <a href={category.href} class="mobile-dropdown-link">
            {category.name}
          </a>
        ))}
      </div>
    </div>

    <a href="#installation" class="mobile-nav-link">{navData.installation}</a>
    <a href="#troubleshooting" class="mobile-nav-link">{navData.troubleshooting}</a>
    <a href="#cost-calculator" class="mobile-nav-link">{navData.costCalculator}</a>
    <a href="#community" class="mobile-nav-link">{navData.community}</a>

    <div class="mobile-lang-switcher">
      <a href={enPath} class:list={[!isZhCN && 'active']}>English</a>
      <span class="divider">/</span>
      <a href={zhPath} class:list={[isZhCN && 'active']}>中文</a>
    </div>
  </div>
</nav>

<style>
  /* ========================================
     钛金属深色拟物化导航栏设计
     ======================================== */

  /* Navbar 基础样式 - 深色金属质感 */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.05) 1px,
        rgba(113, 113, 122, 0.05) 2px
      ),
      linear-gradient(180deg, #1a1f3a 0%, #0a0e27 100%);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 0 15px rgba(228, 228, 231, 0.2),
      0 4px 12px rgba(0, 0, 0, 0.4);
    z-index: 1000;
    height: 65px;
    border-bottom: 2px solid #d4d4d8;
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo - 银色发光效果 */
  .nav-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: #e4e4e7;
    text-decoration: none;
    white-space: nowrap;
    text-shadow:
      0 0 8px rgba(228, 228, 231, 0.5),
      0 0 15px rgba(212, 212, 216, 0.4);
  }

  /* 桌面端菜单 */
  .nav-menu.desktop {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* 导航链接 - 霓虹蓝效果 */
  .nav-link {
    color: #e4e4e7;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: all 0.2s;
    white-space: nowrap;
    padding: 0.5rem 0;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
    position: relative;
  }

  .nav-link:hover {
    color: #e4e4e7;
    text-shadow:
      0 0 8px rgba(228, 228, 231, 0.6),
      0 0 12px rgba(212, 212, 216, 0.5);
  }

  /* 下拉菜单 */
  .nav-item.dropdown {
    position: relative;
  }

  .dropdown-toggle {
    background: none;
    border: none;
    color: #e4e4e7;
    font-weight: 500;
    font-size: 0.9375rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0;
    transition: all 0.2s;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .dropdown-toggle:hover {
    color: #e4e4e7;
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.6);
  }

  .dropdown-arrow {
    transition: transform 0.2s;
  }

  /* 下拉菜单 - 钛金属拟物化卡片效果 */
  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 0 18px rgba(228, 228, 231, 0.3),
      0 12px 32px rgba(0, 0, 0, 0.4);
    padding: 0.75rem 0;
    min-width: 280px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.2s ease;
    margin-top: 8px;
  }

  .nav-item.dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid #d4d4d8;
  }

  .dropdown-item:last-child {
    border-bottom: none;
  }

  .dropdown-link {
    display: block;
    color: #e4e4e7;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .dropdown-link:hover {
    color: #e4e4e7;
    text-shadow: 0 0 12px rgba(228, 228, 231, 0.6);
  }

  .dropdown-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  /* 主题标签 - 银色光晕效果 */
  .topic-tag {
    background: linear-gradient(180deg, rgba(228, 228, 231, 0.2) 0%, rgba(212, 212, 216, 0.15) 100%);
    color: #e4e4e7;
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 8px rgba(228, 228, 231, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.5);
  }

  /* 语言切换器 - 钛金属按钮效果 */
  .lang-switcher {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.875rem;
    padding-left: 1rem;
    border-left: 2px solid #d4d4d8;
  }

  .lang-switcher a {
    text-decoration: none;
    color: #a1a1aa;
    opacity: 0.7;
    transition: all 0.2s;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    background: linear-gradient(180deg, rgba(39, 39, 42, 0.5) 0%, rgba(24, 24, 27, 0.5) 100%);
    border: 1px solid transparent;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .lang-switcher a.active,
  .lang-switcher a:hover {
    opacity: 1;
    font-weight: 600;
    color: #e4e4e7;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, #27272a 0%, #18181b 100%);
    border-color: #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 12px rgba(228, 228, 231, 0.4);
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.6);
  }

  .divider {
    opacity: 0.6;
    color: #d4d4d8;
  }

  /* 移动端菜单按钮 - 钛金属按钮 */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, #27272a 0%, #18181b 100%);
    border: 2px solid #d4d4d8;
    border-radius: 8px;
    cursor: pointer;
    padding: 0.6rem;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 12px rgba(228, 228, 231, 0.3),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .mobile-menu-btn:active {
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.5),
      0 0 8px rgba(228, 228, 231, 0.2);
  }

  .hamburger {
    width: 24px;
    height: 2px;
    background: #e4e4e7;
    transition: all 0.3s;
    box-shadow:
      0 0 5px rgba(212, 212, 216, 0.5),
      0 1px 2px rgba(0, 0, 0, 0.4);
  }

  /* 移动端菜单 - 钛金属质感 */
  .nav-menu.mobile {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.05) 1px,
        rgba(113, 113, 122, 0.05) 2px
      ),
      linear-gradient(180deg, #1a1f3a 0%, #0a0e27 100%);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 0 18px rgba(228, 228, 231, 0.3),
      0 8px 24px rgba(0, 0, 0, 0.5);
    padding: 1rem 0;
    flex-direction: column;
    border-top: 2px solid #d4d4d8;
  }

  .nav-menu.mobile.active {
    display: flex;
  }

  .mobile-nav-link {
    padding: 0.85rem 2rem;
    color: #e4e4e7;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid #d4d4d8;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .mobile-nav-link:hover {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, rgba(39, 39, 42, 0.5) 0%, rgba(24, 24, 27, 0.5) 100%);
    color: #e4e4e7;
    text-shadow: 0 0 12px rgba(228, 228, 231, 0.6);
  }

  /* 移动端下拉菜单 */
  .mobile-dropdown {
    border-bottom: 1px solid #d4d4d8;
  }

  .mobile-dropdown-toggle {
    width: 100%;
    padding: 0.85rem 2rem;
    background: none;
    border: none;
    text-align: left;
    font-weight: 500;
    color: #e4e4e7;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .mobile-dropdown-menu {
    display: none;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, rgba(39, 39, 42, 0.5) 0%, rgba(24, 24, 27, 0.5) 100%);
    padding: 0.5rem 0;
  }

  .mobile-dropdown-menu.active {
    display: block;
  }

  .mobile-dropdown-link {
    display: block;
    padding: 0.6rem 2rem 0.6rem 3rem;
    color: #a1a1aa;
    text-decoration: none;
    font-size: 0.875rem;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .mobile-dropdown-link:hover {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, rgba(39, 39, 42, 0.8) 0%, rgba(24, 24, 27, 0.8) 100%);
    color: #e4e4e7;
    text-shadow: 0 0 12px rgba(228, 228, 231, 0.6);
  }

  .mobile-lang-switcher {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    padding: 1rem 2rem;
    font-size: 0.875rem;
    border-top: 1px solid #d4d4d8;
    background: rgba(39, 39, 42, 0.3);
  }

  .mobile-lang-switcher a {
    text-decoration: none;
    color: #a1a1aa;
    opacity: 0.7;
    transition: all 0.2s;
    font-weight: 500;
    padding: 0.4rem 0.85rem;
    border-radius: 6px;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .mobile-lang-switcher a.active,
  .mobile-lang-switcher a:hover {
    opacity: 1;
    font-weight: 600;
    color: #e4e4e7;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(180deg, #27272a 0%, #18181b 100%);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.2),
      0 0 12px rgba(228, 228, 231, 0.4);
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.6);
  }

  /* 响应式设计 */
  @media (max-width: 1024px) {
    .nav-menu.desktop {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }

    .nav-container {
      padding: 0 1rem;
    }
  }

  @media (max-width: 640px) {
    .nav-logo {
      font-size: 1rem;
    }

    .dropdown-menu {
      min-width: 240px;
    }
  }
</style>

<script>
  // 移动端菜单切换
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');

  mobileMenuBtn?.addEventListener('click', () => {
    if (mobileMenu) {
      mobileMenu.classList.toggle('active');
    }
  });

  // 移动端下拉菜单
  const dropdownToggles = document.querySelectorAll('.mobile-dropdown-toggle');
  dropdownToggles.forEach(toggle => {
    toggle?.addEventListener('click', () => {
      const dropdownId = toggle.getAttribute('data-dropdown');
      if (dropdownId) {
        const dropdown = document.getElementById(dropdownId + 'Dropdown');
        dropdown?.classList.toggle('active');
      }
    });
  });

  // 点击链接后关闭移动端菜单
  const mobileLinks = document.querySelectorAll('.mobile-nav-link, .mobile-dropdown-link');
  mobileLinks.forEach(link => {
    link?.addEventListener('click', () => {
      mobileMenu?.classList.remove('active');
    });
  });

  // 滚动时添加阴影效果
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (navbar) {
      const currentScroll = window.pageYOffset;

      if (currentScroll > 10) {
        navbar.style.boxShadow = 'inset 0 1px 2px rgba(228, 228, 231, 0.2), 0 0 22px rgba(228, 228, 231, 0.35), 0 8px 24px rgba(0, 0, 0, 0.5)';
      } else {
        navbar.style.boxShadow = 'inset 0 1px 2px rgba(228, 228, 231, 0.15), 0 0 15px rgba(228, 228, 231, 0.2), 0 4px 12px rgba(0, 0, 0, 0.4)';
      }
    }
  });
</script>
