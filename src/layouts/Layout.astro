---
import Navigation from '../components/Navigation.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  currentPath?: string;
  lang?: string;
}

const {
  title = 'OpenClaw Tutorials & Troubleshooting',
  description = 'Run OpenClaw in 5 minutes. Fix common issues in 30 seconds.',
  image = '/favicon.webp',
  currentPath,
  lang = 'en'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:image:alt" content={`${title} - OpenClaw Tutorial`} />
    <meta property="og:locale" content={lang === 'zh-CN' ? 'zh_CN' : 'en_US'} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Structured Data -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "OpenClaw Tutorials",
        "url": "https://openclawtutorial.online",
        "description": "OpenClaw Tutorials & Troubleshooting",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://openclawtutorial.online/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "OpenClaw Tutorial",
        "url": "https://openclawtutorial.online",
        "logo": "https://openclawtutorial.online/favicon.webp"
      }
    </script>

    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="layout">
      <Navigation currentPath={currentPath || Astro.url.pathname} />
      <main class="main-content">
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans', Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji';
    line-height: 1.6;
    color: #333;
  }

  .layout {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .main-content {
    flex: 1;
    padding-top: 65px; /* 为固定导航栏留出空间 */
  }

  /* ========================================
     暗色模式全局样式
     ======================================== */
  html.dark-mode body,
  body {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(113, 113, 122, 0.03) 2px,
        rgba(113, 113, 122, 0.03) 4px
      ),
      linear-gradient(
        135deg,
        #0a0e27 0%,
        #1a1f3a 50%,
        #0a0e27 100%
      );
    background-attachment: fixed;
    color: #e4e4e7;
  }

  /* ========================================
     亮色模式全局样式
     ======================================== */
  html.light-mode body {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.02) 2px,
        rgba(0, 0, 0, 0.02) 4px
      ),
      linear-gradient(
        135deg,
        #f9fafb 0%,
        #e5e7eb 50%,
        #f9fafb 100%
      );
    background-attachment: fixed;
    color: #333;
  }
</style>