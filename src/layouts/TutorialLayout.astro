---
import { getCollection } from 'astro:content';
import Navigation from '../components/Navigation.astro';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      lastUpdated?: Date;
      tags: string[];
      difficulty: 'beginner' | 'intermediate' | 'advanced';
      estimatedTime: string;
      prerequisites: string[];
      category?: string;
      prevPost?: string;
      nextPost?: string;
      relatedPosts?: string[];
    };
    body: string;
    render(): Promise<{
      Content: any;
    }>;
  };
}

const { post } = Astro.props;

// 获取所有中文文章用于导航
const allPosts = await getCollection('posts-zh-cn');
const publishedPosts = allPosts.filter(p => p.data.status !== 'draft');

// 分类名称映射（更新为不带编号的版本）
const categoryNames: Record<string, string> = {
  'getting-started': '新手上路',
  'initialization': '初始化小龙虾',
  'claw-eyes': '小龙虾的眼睛',
  'claw-hands': '小龙虾的手脚',
  'claw-brain': '小龙虾的大脑',
  'essential-skills': '必备技能包',
  'multi-agents': '多 Agents 能力',
  'installation': '安装部署',
  'troubleshooting': '疑难解答',
};

// 难度级别映射
const difficultyLabels: Record<string, string> = {
  'beginner': '入门',
  'intermediate': '中级',
  'advanced': '高级',
};

// 获取上一篇和下一篇文章
const getPrevNextPosts = () => {
  const prevPostSlug = post.data.prevPost;
  const nextPostSlug = post.data.nextPost;

  const prevPost = prevPostSlug
    ? publishedPosts.find(p => p.slug === prevPostSlug)
    : null;
  const nextPost = nextPostSlug
    ? publishedPosts.find(p => p.slug === nextPostSlug)
    : null;

  return { prevPost, nextPost };
};

const { prevPost, nextPost } = getPrevNextPosts();

// 获取相关文章
const getRelatedPosts = () => {
  const relatedSlugs = post.data.relatedPosts || [];
  return relatedSlugs
    .map(slug => publishedPosts.find(p => p.slug === slug))
    .filter(Boolean);
};

const relatedPosts = getRelatedPosts();

// 格式化日期
const formatDate = (date: Date) => {
  return new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const { Content } = await post.render();
const currentCategory = post.data.category;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{post.data.title} - OpenClaw 教程</title>
    <meta name="description" content={post.data.description} />
  </head>
  <body>
    <Navigation currentPath={`/zh-cn/tutorials/${currentCategory}/${post.slug}/`} />

    <!-- 目录侧边栏按钮 -->
    <button class="toc-toggle" id="tocToggle" aria-label="打开目录">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- 目录侧边栏 -->
    <div class="toc-sidebar" id="tocSidebar">
      <div class="toc-header">
        <h3>📑 目录</h3>
        <button class="toc-close" id="tocClose" aria-label="关闭目录">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <nav class="toc-nav" id="tocNav">
        <!-- 目录项将通过 JavaScript 动态生成 -->
      </nav>
    </div>

    <!-- 目录遮罩层 -->
    <div class="toc-overlay" id="tocOverlay"></div>

    <div class="tutorial-layout">
      <!-- 面包屑导航 -->
      <nav class="breadcrumb" aria-label="面包屑导航">
        <div class="breadcrumb-container">
          <ol class="breadcrumb-list">
            <li><a href="/zh-cn/">🏠 首页</a></li>
            <li><span class="separator">/</span></li>
            <li><a href="/zh-cn/tutorials/">教程</a></li>
            {currentCategory && (
              <>
                <li><span class="separator">/</span></li>
                <li><a href={`/zh-cn/tutorials/${currentCategory}/`}>{categoryNames[currentCategory]}</a></li>
              </>
            )}
            <li><span class="separator">/</span></li>
            <li class="active" aria-current="page">{post.data.title}</li>
          </ol>
        </div>
      </nav>

      <!-- 文章容器 -->
      <article class="tutorial-article">
        <!-- 文章头部 -->
        <header class="article-header">
          <h1 class="article-title">{post.data.title}</h1>
          <p class="article-description">{post.data.description}</p>

          <div class="article-meta">
            <div class="meta-item">
              <span class="meta-icon">📅</span>
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
            </div>

            {post.data.lastUpdated && (
              <div class="meta-item">
                <span class="meta-icon">🔄</span>
                <span>更新于 {formatDate(post.data.lastUpdated)}</span>
              </div>
            )}

            <div class="meta-item">
              <span class="meta-icon">⏱️</span>
              <span>{post.data.estimatedTime}</span>
            </div>

            <div class="meta-item">
              <span class={`difficulty-badge difficulty-${post.data.difficulty}`}>
                {difficultyLabels[post.data.difficulty]}
              </span>
            </div>
          </div>

          {post.data.prerequisites.length > 0 && (
            <div class="prerequisites">
              <strong>⚡ 前置要求</strong>
              <ul class="prerequisites-list">
                {post.data.prerequisites.map(prereq => (
                  <li>{prereq}</li>
                ))}
              </ul>
            </div>
          )}

          {post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </header>

        <!-- 文章内容 -->
        <div class="article-content">
          <Content />
        </div>

        <!-- 文章导航 -->
        {(prevPost || nextPost) && (
          <nav class="tutorial-nav" aria-label="文章导航">
            {prevPost && (
              <a
                href={`/zh-cn/tutorials/${currentCategory || 'posts'}/${prevPost.slug}/`}
                class="nav-link prev-post titanium-button-secondary"
              >
                <span class="nav-icon">←</span>
                <div class="nav-content">
                  <span class="nav-label">上一篇</span>
                  <span class="nav-title">{prevPost.data.title}</span>
                </div>
              </a>
            )}

            {nextPost && (
              <a
                href={`/zh-cn/tutorials/${currentCategory || 'posts'}/${nextPost.slug}/`}
                class="nav-link next-post titanium-button-secondary"
              >
                <div class="nav-content">
                  <span class="nav-label">下一篇</span>
                  <span class="nav-title">{nextPost.data.title}</span>
                </div>
                <span class="nav-icon">→</span>
              </a>
            )}
          </nav>
        )}

        <!-- 返回分类链接 -->
        {currentCategory && (
          <div class="back-to-category">
            <a href={`/zh-cn/tutorials/${currentCategory}/`} class="titanium-button">
              ← 返回 {categoryNames[currentCategory]}
            </a>
          </div>
        )}

        <!-- 相关文章推荐 -->
        {relatedPosts.length > 0 && (
          <aside class="related-posts">
            <h3>📚 相关文章推荐</h3>
            <div class="related-posts-grid">
              {relatedPosts.map((relatedPost) => (
                relatedPost && (
                  <a
                    href={`/zh-cn/tutorials/${relatedPost.data.category || 'posts'}/${relatedPost.slug}/`}
                    class="related-post-card titanium-card"
                  >
                    <h4>{relatedPost.data.title}</h4>
                    <p>{relatedPost.data.description}</p>
                    <div class="related-post-meta">
                      <span class={`difficulty-badge difficulty-${relatedPost.data.difficulty}`}>
                        {difficultyLabels[relatedPost.data.difficulty]}
                      </span>
                      <span class="time">⏱️ {relatedPost.data.estimatedTime}</span>
                    </div>
                  </a>
                )
              ))}
            </div>
          </aside>
        )}
      </article>
    </div>

    <script>
      // 为所有代码块添加复制按钮
      document.addEventListener('DOMContentLoaded', () => {
        const codeBlocks = document.querySelectorAll('.article-content pre');

        codeBlocks.forEach((pre) => {
          // 创建复制按钮
          const copyButton = document.createElement('button');
          copyButton.className = 'copy-button';
          copyButton.innerHTML = `
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span class="copy-text">复制</span>
          `;

          // 插入按钮到 pre 元素
          (pre as HTMLElement).style.position = 'relative';
          pre.appendChild(copyButton);

          // 点击复制
          copyButton.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            const text = code ? code.textContent : pre.textContent;

            try {
              await navigator.clipboard.writeText(text);

              // 显示成功状态
              copyButton.classList.add('copied');
              const copyText = copyButton.querySelector('.copy-text');
              if (copyText) {
                copyText.textContent = '已复制';
              }

              // 2秒后恢复
              setTimeout(() => {
                copyButton.classList.remove('copied');
                const copyText = copyButton.querySelector('.copy-text');
                if (copyText) {
                  copyText.textContent = '复制';
                }
              }, 2000);
            } catch (err) {
              console.error('复制失败:', err);
              const copyText = copyButton.querySelector('.copy-text');
              if (copyText) {
                copyText.textContent = '失败';
              }

              setTimeout(() => {
                const copyText = copyButton.querySelector('.copy-text');
                if (copyText) {
                  copyText.textContent = '复制';
                }
              }, 2000);
            }
          });
        });
      });
    </script>

    <script>
      // 目录功能
      document.addEventListener('DOMContentLoaded', () => {
        const tocToggle = document.getElementById('tocToggle');
        const tocSidebar = document.getElementById('tocSidebar');
        const tocClose = document.getElementById('tocClose');
        const tocOverlay = document.getElementById('tocOverlay');
        const tocNav = document.getElementById('tocNav');
        const articleContent = document.querySelector('.article-content');

        // 打开目录
        const openToc = () => {
          if (tocSidebar) tocSidebar.classList.add('active');
          if (tocOverlay) tocOverlay.classList.add('active');
          document.body.style.overflow = 'hidden';
        };

        // 关闭目录
        const closeToc = () => {
          if (tocSidebar) tocSidebar.classList.remove('active');
          if (tocOverlay) tocOverlay.classList.remove('active');
          document.body.style.overflow = '';
        };

        // 提取标题生成目录
        const generateToc = () => {
          if (!articleContent || !tocNav) return;

          const headings = articleContent.querySelectorAll('h2, h3');
          if (headings.length === 0) {
            if (tocToggle) tocToggle.style.display = 'none';
            return;
          }

          const tocList = [];

          headings.forEach((heading, index) => {
            // 为每个标题添加 ID
            if (!heading.id) {
              heading.id = `heading-${index}`;
            }

            const tocItem = document.createElement('a');
            tocItem.href = `#${heading.id}`;
            tocItem.className = `toc-item ${heading.tagName.toLowerCase()}`;
            tocItem.textContent = heading.textContent;
            tocItem.dataset.target = heading.id;

            tocNav.appendChild(tocItem);
            tocList.push({ element: heading, link: tocItem });

            // 点击目录项
            tocItem.addEventListener('click', (e) => {
              e.preventDefault();
              const target = document.getElementById(heading.id);
              if (target) {
                const navbarHeight = 65;
                const targetPosition = target.offsetTop - navbarHeight - 20;

                window.scrollTo({
                  top: targetPosition,
                  behavior: 'smooth'
                });

                closeToc();
              }
            });
          });

          // 监听滚动，高亮当前章节
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  const id = entry.target.id;
                  tocNav.querySelectorAll('.toc-item').forEach((item) => {
                    item.classList.remove('active');
                    if ((item as HTMLElement).dataset.target === id) {
                      item.classList.add('active');
                    }
                  });
                }
              });
            },
            {
              rootMargin: '-80px 0px -70% 0px',
              threshold: 0
            }
          );

          headings.forEach((heading) => {
            if (heading.id) {
              observer.observe(heading);
            }
          });
        };

        // 事件监听
        tocToggle?.addEventListener('click', openToc);
        tocClose?.addEventListener('click', closeToc);
        tocOverlay?.addEventListener('click', closeToc);

        // ESC 键关闭
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && tocSidebar?.classList.contains('active')) {
            closeToc();
          }
        });

        // 生成目录
        generateToc();
      });
    </script>
  </body>
</html>

<style is:global>
  /* ========================================
     钛金属深色拟物化设计风格
     ======================================== */

  /* 全局重置和基础样式 */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC',
                 'Microsoft YaHei', Helvetica, Arial, sans-serif,
                 'Apple Color Emoji', 'Segoe UI Emoji';
    line-height: 1.6;
    color: #e4e4e7;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(113, 113, 122, 0.03) 2px,
        rgba(113, 113, 122, 0.03) 4px
      ),
      linear-gradient(
        135deg,
        #0a0e27 0%,
        #1a1f3a 50%,
        #0a0e27 100%
      );
    background-attachment: fixed;
    min-height: 100vh;
  }

  .tutorial-layout {
    max-width: 1000px;
    margin: 0 auto;
    padding: 5rem 2rem 4rem 2rem;
  }

  /* ========================================
     面包屑导航 - 钛金属风格
     ======================================== */
  .breadcrumb {
    padding: 1rem 0;
    margin-bottom: 2.5rem;
  }

  .breadcrumb-container {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, rgba(39, 39, 42, 0.8) 0%, rgba(24, 24, 27, 0.8) 100%);
    border-radius: 8px;
    padding: 1rem 1.5rem;
    border: 1px solid rgba(212, 212, 216, 0.3);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 4px 12px rgba(0, 0, 0, 0.3);
  }

  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.875rem;
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
  }

  .breadcrumb .separator {
    color: #71717a;
    margin: 0 0.5rem;
  }

  .breadcrumb a {
    color: #a1a1aa;
    text-decoration: none;
    transition: all 0.2s;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .breadcrumb a:hover {
    color: #e4e4e7;
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.6);
  }

  .breadcrumb .active {
    color: #e4e4e7;
    font-weight: 500;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.5);
  }

  /* ========================================
     文章容器 - 钛金属卡片
     ======================================== */
  .tutorial-article {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 12px;
    padding: 3rem;
    border: 2px solid #e4e4e7;
    box-shadow:
      inset 0 2px 4px rgba(228, 228, 231, 0.15),
      inset 0 -2px 4px rgba(0, 0, 0, 0.4),
      0 0 20px rgba(228, 228, 231, 0.2),
      0 8px 24px rgba(0, 0, 0, 0.4);
  }

  /* ========================================
     文章头部 - 钛金属风格
     ======================================== */
  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid rgba(212, 212, 216, 0.3);
  }

  .article-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    margin-bottom: 1.25rem;
    color: #e4e4e7;
    line-height: 1.4;
    text-shadow:
      0 0 15px rgba(228, 228, 231, 0.5),
      0 0 30px rgba(228, 228, 231, 0.3),
      0 4px 8px rgba(0, 0, 0, 0.5);
    letter-spacing: 0.02em;
  }

  .article-description {
    font-size: 1.125rem;
    color: #a1a1aa;
    margin-bottom: 1.75rem;
    line-height: 1.6;
    text-shadow: 0 0 6px rgba(161, 161, 170, 0.4);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.75rem;
    color: #a1a1aa;
    font-size: 0.9375rem;
    margin-bottom: 1.25rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .meta-icon {
    font-size: 1.125rem;
    filter: drop-shadow(0 0 6px rgba(161, 161, 170, 0.5));
  }

  /* 难度徽章 - 钛金属风格 */
  .difficulty-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    border: 1px solid rgba(212, 212, 216, 0.4);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.15),
      0 0 8px rgba(228, 228, 231, 0.3);
    text-shadow: 0 0 4px rgba(228, 228, 231, 0.5);
  }

  .difficulty-beginner {
    background:
      repeating-linear-gradient(
        90deg,
        #059669,
        #10b981 2px,
        #059669 4px
      );
    color: #e4e4e7;
  }

  .difficulty-intermediate {
    background:
      repeating-linear-gradient(
        90deg,
        #d97706,
        #f59e0b 2px,
        #d97706 4px
      );
    color: #e4e4e7;
  }

  .difficulty-advanced {
    background:
      repeating-linear-gradient(
        90deg,
        #dc2626,
        #ef4444 2px,
        #dc2626 4px
      );
    color: #e4e4e7;
  }

  /* 前置要求 - 钛金属风格 */
  .prerequisites {
    margin-top: 1.5rem;
    padding: 1.5rem;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.08) 1px,
        rgba(113, 113, 122, 0.08) 2px
      ),
      linear-gradient(135deg, rgba(39, 39, 42, 0.6) 0%, rgba(24, 24, 27, 0.6) 100%);
    border-left: 4px solid #d4d4d8;
    border-radius: 8px;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.1),
      0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .prerequisites strong {
    display: block;
    margin-bottom: 0.75rem;
    color: #e4e4e7;
    font-size: 1rem;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .prerequisites-list {
    list-style: none;
    padding-left: 0;
  }

  .prerequisites-list li {
    padding: 0.5rem 0;
    position: relative;
    padding-left: 1.75rem;
    color: #a1a1aa;
    font-size: 1rem;
  }

  .prerequisites-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #10b981;
    font-weight: bold;
    text-shadow: 0 0 6px rgba(16, 185, 129, 0.6);
  }

  /* 标签 - 钛金属风格 */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: linear-gradient(180deg, rgba(161, 161, 170, 0.2) 0%, rgba(113, 113, 122, 0.15) 100%);
    color: #e4e4e7;
    border: 1px solid rgba(212, 212, 216, 0.3);
    border-radius: 4px;
    font-size: 0.875rem;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 0 6px rgba(228, 228, 231, 0.2);
    text-shadow: 0 0 4px rgba(228, 228, 231, 0.4);
  }

  /* ========================================
     文章内容 - 钛金属风格
     ======================================== */
  .article-content {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #d4d4d8;
  }

  .article-content h2 {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: #e4e4e7;
    border-bottom: 2px solid rgba(212, 212, 216, 0.3);
    padding-bottom: 0.5rem;
    text-shadow:
      0 0 10px rgba(228, 228, 231, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .article-content h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: #e4e4e7;
    text-shadow:
      0 0 8px rgba(228, 228, 231, 0.4),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .article-content h4 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: #d4d4d8;
    text-shadow: 0 0 6px rgba(212, 212, 216, 0.3);
  }

  .article-content p {
    margin-bottom: 1.25rem;
  }

  .article-content ul,
  .article-content ol {
    margin-bottom: 1.25rem;
    padding-left: 2rem;
  }

  .article-content li {
    margin-bottom: 0.5rem;
    color: #d4d4d8;
  }

  .article-content code {
    background:
      repeating-linear-gradient(
        90deg,
        rgba(113, 113, 122, 0.2),
        rgba(113, 113, 122, 0.2) 2px,
        rgba(161, 161, 170, 0.15) 2px,
        rgba(161, 161, 170, 0.15) 4px
      );
    color: #e4e4e7;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-size: 0.9375em;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    border: 1px solid rgba(212, 212, 216, 0.2);
    box-shadow:
      inset 0 1px 2px rgba(0, 0, 0, 0.3),
      0 1px 2px rgba(228, 228, 231, 0.1);
  }

  .article-content pre {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #1f2937 0%, #111827 100%);
    color: #f9fafb;
    padding: 1.5rem;
    border-radius: 8px;
    border: 2px solid rgba(212, 212, 216, 0.2);
    overflow-x: auto;
    margin-bottom: 1.5rem;
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.5),
      0 4px 12px rgba(0, 0, 0, 0.3);
  }

  .article-content pre code {
    background: transparent;
    padding: 0;
    color: inherit;
    border: none;
    box-shadow: none;
  }

  .article-content blockquote {
    border-left: 4px solid #d4d4d8;
    padding-left: 1rem;
    margin: 1.5rem 0;
    padding: 1rem 1.5rem;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.08) 1px,
        rgba(113, 113, 122, 0.08) 2px
      ),
      linear-gradient(135deg, rgba(39, 39, 42, 0.4) 0%, rgba(24, 24, 27, 0.4) 100%);
    border-radius: 8px;
    color: #a1a1aa;
    font-style: italic;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.1),
      0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .article-content a {
    color: #a1a1aa;
    text-decoration: none;
    transition: all 0.2s;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .article-content a:hover {
    color: #e4e4e7;
    text-shadow:
      0 0 8px rgba(228, 228, 231, 0.6),
      0 0 16px rgba(228, 228, 231, 0.4);
  }

  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(212, 212, 216, 0.2);
  }

  .article-content th,
  .article-content td {
    border: 1px solid rgba(212, 212, 216, 0.15);
    padding: 0.75rem;
    text-align: left;
  }

  .article-content th {
    background:
      repeating-linear-gradient(
        90deg,
        rgba(113, 113, 122, 0.3),
        rgba(113, 113, 122, 0.3) 2px,
        rgba(161, 161, 170, 0.2) 2px,
        rgba(161, 161, 170, 0.2) 4px
      );
    color: #e4e4e7;
    font-weight: 600;
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
  }

  .article-content td {
    color: #d4d4d8;
  }

  /* ========================================
     文章导航 - 钛金属风格
     ======================================== */
  .tutorial-nav {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 4rem;
  }

  .nav-link {
    flex: 1;
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 1rem;
    border-radius: 8px;
  }

  .nav-link.prev-post {
    justify-content: flex-start;
  }

  .nav-link.next-post {
    justify-content: flex-end;
  }

  .nav-icon {
    font-size: 1.5rem;
    color: #e4e4e7;
    text-shadow: 0 0 8px rgba(228, 228, 231, 0.6);
    transition: transform 0.2s;
  }

  .nav-link:hover .nav-icon {
    transform: scale(1.2);
  }

  .nav-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .nav-link.next-post .nav-content {
    align-items: flex-end;
  }

  .nav-label {
    color: #71717a;
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .nav-title {
    color: #e4e4e7;
    font-weight: 600;
    font-size: 1.0625rem;
    text-shadow:
      0 0 8px rgba(228, 228, 231, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }

  /* 钛金属按钮次要样式 */
  .titanium-button-secondary {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, rgba(39, 39, 42, 0.6) 0%, rgba(24, 24, 27, 0.6) 100%);
    color: #e4e4e7;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    border: 2px solid rgba(212, 212, 216, 0.4);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 15px rgba(228, 228, 231, 0.2),
      0 4px 8px rgba(0, 0, 0, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
    transition: all 0.2s;
  }

  .titanium-button-secondary:hover {
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2),
      0 0 22px rgba(228, 228, 231, 0.35),
      0 8px 16px rgba(0, 0, 0, 0.4);
  }

  /* 返回分类链接 */
  .back-to-category {
    margin-top: 2rem;
    text-align: center;
  }

  .titanium-button {
    display: inline-block;
    background: linear-gradient(180deg, #71717a 0%, #52525b 50%, #3f3f46 100%);
    color: #e4e4e7;
    padding: 1rem 2.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    border: 2px solid #d4d4d8;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.2),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 15px rgba(228, 228, 231, 0.3),
      0 4px 8px rgba(0, 0, 0, 0.3);
    text-shadow: 0 0 6px rgba(228, 228, 231, 0.4);
    transition: all 0.15s ease;
  }

  .titanium-button:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.2),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 22px rgba(228, 228, 231, 0.4),
      0 6px 12px rgba(0, 0, 0, 0.4);
  }

  .titanium-button:active {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.4),
      inset 0 -1px 2px rgba(255, 255, 255, 0.1),
      0 0 12px rgba(228, 228, 231, 0.3);
  }

  /* ========================================
     相关文章 - 钛金属风格
     ======================================== */
  .related-posts {
    margin-top: 4rem;
    padding: 2rem;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.08) 1px,
        rgba(113, 113, 122, 0.08) 2px
      ),
      linear-gradient(135deg, rgba(39, 39, 42, 0.4) 0%, rgba(24, 24, 27, 0.4) 100%);
    border-radius: 12px;
    border: 2px solid rgba(212, 212, 216, 0.3);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      0 0 18px rgba(228, 228, 231, 0.2),
      0 8px 16px rgba(0, 0, 0, 0.3);
  }

  .related-posts h3 {
    margin-bottom: 2rem;
    font-size: 1.5rem;
    color: #e4e4e7;
    text-shadow:
      0 0 12px rgba(228, 228, 231, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  /* 钛金属卡片 */
  .titanium-card {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 1px,
        rgba(113, 113, 122, 0.1) 1px,
        rgba(113, 113, 122, 0.1) 2px
      ),
      linear-gradient(135deg, #27272a 0%, #18181b 100%);
    border-radius: 8px;
    padding: 1.5rem;
    border: 2px solid rgba(228, 228, 231, 0.3);
    text-decoration: none;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 12px rgba(228, 228, 231, 0.2),
      0 4px 8px rgba(0, 0, 0, 0.3);
  }

  .titanium-card:hover {
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 2px rgba(228, 228, 231, 0.15),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(228, 228, 231, 0.35),
      0 8px 16px rgba(0, 0, 0, 0.4);
  }

  .related-post-card h4 {
    margin-bottom: 0.5rem;
    color: #e4e4e7;
    font-size: 1.125rem;
    text-shadow:
      0 0 8px rgba(228, 228, 231, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .related-post-card p {
    color: #a1a1aa;
    font-size: 0.9375rem;
    margin-bottom: 1rem;
    flex: 1;
    text-shadow: 0 0 4px rgba(161, 161, 170, 0.3);
  }

  .related-post-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.875rem;
  }

  .related-post-meta .time {
    color: #a1a1aa;
  }

  /* ========================================
     响应式设计
     ======================================== */
  @media (max-width: 768px) {
    .tutorial-layout {
      padding: 6.5rem 0.5rem 3rem 0.5rem;
    }

    .tutorial-article {
      padding: 2rem 1.5rem;
    }

    .article-title {
      font-size: 1.875rem;
    }

    .article-description {
      font-size: 1rem;
    }

    .article-meta {
      flex-direction: column;
      gap: 0.75rem;
    }

    .tutorial-nav {
      flex-direction: column;
    }

    .nav-link {
      width: 100%;
    }

    .related-posts-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .tutorial-article {
      padding: 1.5rem 1rem;
    }

    .breadcrumb-container {
      padding: 0.75rem 1rem;
    }

    .article-title {
      font-size: 1.5rem;
    }
  }

