# GitHub API Token (可选，提高请求限制)
# 获取方式: https://github.com/settings/tokens
# 需要的权限: repo (public_repo)
GITHUB_TOKEN=

# DeepL API Key (用于翻译，推荐)
# 获取方式: https://www.deepl.com/pro-api
# 免费额度: 每月 50 万字符
DEEPL_API_KEY=

# OpenAI API Key (用于翻译的备选方案)
# 获取方式: https://platform.openai.com/api-keys
# 需要模型: gpt-3.5-turbo
OPENAI_API_KEY=

# 注意:
# 1. 复制此文件为 .env 并填入实际的 API Key
# 2. .env 文件已在 .gitignore 中，不会被提交到 Git
# 3. 只需要配置一个翻译 API（DeepL 或 OpenAI）
# 4. 如果不配置翻译 API，脚本只会收集英文内容
